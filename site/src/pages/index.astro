<script>
	// Copy-to-clipboard for the install command pills (progressive; no-op
	// without clipboard support).
	for (const btn of document.querySelectorAll('.copy-btn')) {
		btn.addEventListener('click', () => {
			const cmd = btn.getAttribute('data-cmd') || '';
			navigator.clipboard?.writeText(cmd);
			const prev = btn.innerHTML;
			btn.innerHTML = '<span>Copied</span>';
			window.setTimeout(() => { btn.innerHTML = prev; }, 1300);
		});
	}

	// Light/dark toggle — persisted; BaseLayout (theme="auto") reads mm-theme
	// pre-paint so there's no flash.
	const root = document.documentElement;
	for (const b of document.querySelectorAll('[data-toggle-theme]')) {
		b.addEventListener('click', () => {
			const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
			root.dataset.theme = next;
			try {
				localStorage.setItem('mm-theme', next);
			} catch {}
		});
	}
</script>
