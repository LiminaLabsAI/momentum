---
/**
 * <IDEMatrix /> — shows which AI agents momentum supports.
 *
 * Grid on desktop; stacks to one column on mobile.
 */
// Status legend:
//   available  — Claude Code: shipped + live-runtime verified
//   preview    — Codex / Antigravity: installs ship, full live-runtime
//                smoke pending (VAL-001 + VAL-002)
//   planned    — Cursor / Gemini CLI: adapter not yet built
const agents = [
	{ name: 'Claude Code', status: 'available', file: 'CLAUDE.md', anchor: 'claude-code' },
	{ name: 'Codex', status: 'preview', file: 'AGENTS.md', anchor: 'codex' },
	{ name: 'Antigravity', status: 'preview', file: 'AGENTS.md', anchor: 'antigravity' },
	{ name: 'Cursor', status: 'planned', file: '.cursor/rules/', anchor: 'cursor' },
	{ name: 'Gemini CLI', status: 'planned', file: 'GEMINI.md', anchor: 'gemini-cli' },
];

const statusLabel = {
	available: 'Available',
	preview: 'Testing pending',
	planned: 'Planned',
};
---

<section class="ide-matrix" aria-labelledby="ide-matrix-heading">
	<h2 id="ide-matrix-heading">Works with any AI&nbsp;IDE</h2>
	<p class="lead">
		Same commands, same workflow, every agent. Brings momentum's discipline
		into whichever IDE your team already uses.
	</p>
	<ul class="agents">
		{
			agents.map((agent) => (
				<li class={`agent agent--${agent.status}`}>
					<a href={`/ide-support/#${agent.anchor}`}>
						<span class="agent-name">{agent.name}</span>
						<span class="agent-meta">
							<code>{agent.file}</code>
							<span class={`badge badge--${agent.status}`}>
								{statusLabel[agent.status]}
							</span>
						</span>
					</a>
				</li>
			))
		}
	</ul>
</section>

<style>
	.ide-matrix {
		margin: 3rem 0 4rem;
	}
	.ide-matrix h2 {
		font-size: 1.75rem;
		font-weight: 650;
		letter-spacing: -0.02em;
		margin: 0 0 0.25rem;
	}
	.ide-matrix .lead {
		color: var(--brand-text-muted);
		max-width: 38em;
		margin: 0 0 1.5rem;
	}
	.agents {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 0.75rem;
	}
	.agent a {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1rem 1.1rem;
		border-radius: 10px;
		background: var(--brand-surface-subtle);
		border: 1px solid var(--brand-border);
		text-decoration: none;
		color: var(--brand-text);
		transition: border-color var(--brand-duration-fast) var(--brand-ease),
			transform var(--brand-duration-fast) var(--brand-ease);
	}
	.agent a:hover {
		border-color: var(--brand-primary);
		transform: translateY(-1px);
	}
	.agent-name {
		font-weight: 600;
		font-size: 1rem;
	}
	.agent-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		font-size: 0.85rem;
	}
	.agent-meta code {
		font-family: var(--brand-font-mono);
		color: var(--brand-text-muted);
		background: transparent;
		padding: 0;
	}
	.badge {
		display: inline-flex;
		align-items: center;
		padding: 0.15rem 0.55rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}
	.badge--available {
		background: var(--brand-primary-soft);
		color: var(--brand-primary);
	}
	.badge--preview {
		background: rgba(217, 119, 6, 0.14); /* amber-600 @ 14% */
		color: #b45309; /* amber-700 */
	}
	:global([data-theme='dark']) .badge--preview {
		background: rgba(251, 191, 36, 0.18); /* amber-400 @ 18% */
		color: #fbbf24; /* amber-400 */
	}
	.badge--planned {
		background: var(--brand-surface-muted);
		color: var(--brand-text-subtle);
	}
</style>
