---
/**
 * Brand — the momentum "fast-forward" mark (three chevrons as a speed trail)
 * + optional wordmark. Per the brand kit:
 *   - cobalt (#0023AE) on light, white on dark (via currentColor)
 *   - one forward sweep on the first page load of a session, and again on
 *     hover of the whole lockup (mark OR wordmark) — never looping
 *   - honours prefers-reduced-motion (the mark just appears)
 *
 * Triggers are JS-assisted for reliability (a CSS-only :hover duration swap
 * does NOT restart a finished animation). Load-once-per-session is decided
 * pre-paint in BaseLayout (adds `html.mm-swept` on later navigations); hover
 * restarts via the `.mm-sweep` class below. Static raster/vector variants
 * live in /public/brand/ (favicons, app icons).
 */
interface Props {
	/** Render the "momentum" wordmark next to the mark. */
	wordmark?: boolean;
	/** Mark size in px. */
	size?: number;
	/** Link target. */
	href?: string;
	/** Extra class on the anchor. */
	class?: string;
}
const { wordmark = false, size = 28, href = '/', class: cls = '' } = Astro.props;
---

<a class:list={['mm-brand', cls]} href={href} aria-label="momentum">
	<svg
		class="mm-mark"
		viewBox="0 0 48 48"
		width={size}
		height={size}
		fill="none"
		aria-hidden="true"
	>
		<path class="c c1" d="M11 15 20 24 11 33"></path>
		<path class="c c2" d="M20 15 29 24 20 33"></path>
		<path class="c c3" d="M29 15 38 24 29 33"></path>
	</svg>
	{wordmark && <span class="mm-word">momentum</span>}
	<slot />
</a>

<style is:global>
	.mm-brand {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		text-decoration: none;
		/* mark colour — the only brand hue; white on dark surfaces */
		color: var(--brand-ink);
	}
	[data-theme='dark'] .mm-brand {
		color: #fff;
	}
	.mm-brand .mm-word {
		font-weight: 600;
		font-size: 16px;
		letter-spacing: -0.03em;
		line-height: 1;
		color: var(--fg-0);
	}
	.mm-brand .mm-mark {
		display: block;
		flex: none;
	}
	.mm-brand .mm-mark .c {
		stroke: currentColor;
		stroke-width: 5;
		stroke-linecap: round;
		stroke-linejoin: round;
		transform-box: fill-box;
		transform-origin: center;
		opacity: var(--b); /* resting speed-trail */
	}
	.mm-brand .mm-mark .c1 {
		--b: 0.3;
	}
	.mm-brand .mm-mark .c2 {
		--b: 0.6;
	}
	.mm-brand .mm-mark .c3 {
		--b: 1;
	}
	/* Load sweep — only on the first page of a session; BaseLayout adds
	   html.mm-swept (pre-paint) on later navigations so it stays static.
	   :where() keeps the gate at zero specificity so the hover rule (below)
	   always wins when .mm-sweep is present, even on the first page. */
	:where(html:not(.mm-swept)) .mm-brand .mm-mark .c {
		animation: mm-brand-in 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) both;
	}
	:where(html:not(.mm-swept)) .mm-brand .mm-mark .c2 {
		animation-delay: 0.09s;
	}
	:where(html:not(.mm-swept)) .mm-brand .mm-mark .c3 {
		animation-delay: 0.18s;
	}
	/* Hover sweep — JS toggles .mm-sweep on mouseenter for a reliable restart. */
	.mm-brand.mm-sweep .mm-mark .c {
		animation: mm-brand-in 0.5s cubic-bezier(0.2, 0.7, 0.2, 1) both;
	}
	.mm-brand.mm-sweep .mm-mark .c2 {
		animation-delay: 0.09s;
	}
	.mm-brand.mm-sweep .mm-mark .c3 {
		animation-delay: 0.18s;
	}
	@keyframes mm-brand-in {
		from {
			opacity: 0;
			transform: translateX(-6px);
		}
		to {
			opacity: var(--b);
			transform: none;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.mm-brand .mm-mark .c {
			animation: none !important;
			opacity: var(--b);
		}
	}
</style>

<script>
	const html = document.documentElement;
	// Once the first-session load sweep has played, mark <html> swept so the
	// persistent load rule releases — otherwise it keeps the same-named
	// animation on the mark and hover can't restart it. (Later navigations
	// already get .mm-swept pre-paint from BaseLayout.)
	if (!html.classList.contains('mm-swept')) {
		window.setTimeout(() => html.classList.add('mm-swept'), 850);
	}

	// Hover sweep — replay on mouseenter of the whole lockup (mark OR
	// wordmark). remove → reflow → re-add restarts the CSS animation reliably.
	const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
	for (const brand of document.querySelectorAll('.mm-brand')) {
		brand.addEventListener('mouseenter', () => {
			if (reduce.matches) return;
			brand.classList.remove('mm-sweep');
			void brand.getBoundingClientRect(); // force reflow so re-add restarts
			brand.classList.add('mm-sweep');
		});
	}
</script>
