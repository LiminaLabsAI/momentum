---
/**
 * <OrchestrationShowcase /> — landing section: "Work across multiple
 * projects" pillar. Hosts TWO clearly-labeled sub-features (Ecosystem
 * mode = STATE; Orchestration = ACTION) with the StateActionLayers
 * diagram between them, plus a 4-primitive grid for the orchestration
 * sub-feature.
 */
import StateActionLayers from './diagrams/StateActionLayers.astro';

const primitives = [
	{
		name: 'scout',
		oneLine: 'Read-only context fetch',
		body:
			'Pull a structured summary from any project without opening a session there. Returns a deterministic shape (status, active phase, recent decisions).',
		anchor: 'scout',
		icon: 'scout',
	},
	{
		name: 'dispatch',
		oneLine: 'Parallel multi-project fan-out',
		body:
			'One question, N sub-agents. Each gets a scoped prompt tailored to its project, runs in parallel, and the originating agent synthesizes the answer from the structured results.',
		anchor: 'dispatch',
		icon: 'dispatch',
	},
	{
		name: 'handoff',
		oneLine: 'Cross-session control transfer',
		body:
			'Pause work here, hand the receiver a structured context block. The receiving session reads the block first, picks up exactly where you left off — no re-explaining.',
		anchor: 'handoff',
		icon: 'handoff',
	},
	{
		name: 'continue',
		oneLine: 'Pick up a pending handoff',
		body:
			'Idempotent inbox check. SessionStart auto-greets pending handoffs (where the IDE supports hooks); /continue works everywhere.',
		anchor: 'continue',
		icon: 'continue',
	},
];
---

<section class="orch-showcase" aria-labelledby="orch-heading">
	<header class="orch-header">
		<p class="eyebrow">Multi-project coordination</p>
		<h2 id="orch-heading">Work across multiple projects.</h2>
		<p class="lead">
			One agent session works across all of them — no context switching,
			full ecosystem awareness, every project's per-project discipline
			preserved. Two complementary layers make it work:
		</p>
	</header>

	{/* ── Sub-feature 1: Ecosystem mode (STATE layer) ───────────────── */}
	<article class="subfeature" aria-labelledby="sf-ecosystem-heading">
		<header class="subfeature-head">
			<p class="subfeature-eyebrow">State layer</p>
			<h3 id="sf-ecosystem-heading">Ecosystem mode</h3>
		</header>
		<p>
			A shared <strong>ecosystem.json</strong>, <strong>initiatives/</strong>
			for cross-project features, and a <strong>daily session log</strong>
			that auto-records commits and PRs across every member. Pointer blocks
			in each project tell the agent it's part of an ecosystem.
			Per-project state is unchanged; ecosystem mode is purely additive.
		</p>
		<a class="cta-link" href="/ecosystem/">Read the ecosystem deep dive →</a>
	</article>

	{/* ── The relationship diagram ─────────────────────────────────── */}
	<StateActionLayers />

	{/* ── Sub-feature 2: Orchestration (ACTION layer) ───────────────── */}
	<article class="subfeature" aria-labelledby="sf-orch-heading">
		<header class="subfeature-head">
			<p class="subfeature-eyebrow">Action layer</p>
			<h3 id="sf-orch-heading">Orchestration primitives</h3>
		</header>
		<p>
			Four verbs the agent composes per task — not a pipeline. Each
			primitive ships three invocation doors (slash command, natural-language
			inference, CLI) over one shared library, so behavior is identical no
			matter how you reach for it.
		</p>
	</article>

	<ul class="primitives" role="list">
		{
			primitives.map((p) => (
				<li>
					<a class="primitive" href={`/orchestration/#${p.anchor}`}>
						<header class="primitive-head">
							<span class="primitive-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									{p.icon === 'scout' && (
										<>
											<circle cx="11" cy="11" r="7" />
											<line x1="21" y1="21" x2="16.5" y2="16.5" />
										</>
									)}
									{p.icon === 'dispatch' && (
										<>
											<circle cx="12" cy="5" r="2" />
											<circle cx="5" cy="19" r="2" />
											<circle cx="12" cy="19" r="2" />
											<circle cx="19" cy="19" r="2" />
											<line x1="12" y1="7" x2="5" y2="17" />
											<line x1="12" y1="7" x2="12" y2="17" />
											<line x1="12" y1="7" x2="19" y2="17" />
										</>
									)}
									{p.icon === 'handoff' && (
										<>
											<rect x="3" y="6" width="7" height="12" rx="1" />
											<rect x="14" y="6" width="7" height="12" rx="1" />
											<polyline points="10 12 14 12" />
											<polyline points="12 10 14 12 12 14" />
										</>
									)}
									{p.icon === 'continue' && (
										<>
											<polygon points="5 4 5 20 19 12 5 4" />
										</>
									)}
								</svg>
							</span>
							<div>
								<h3>
									<code>{p.name}</code>
								</h3>
								<p class="primitive-tagline">{p.oneLine}</p>
							</div>
						</header>
						<p class="primitive-body">{p.body}</p>
					</a>
				</li>
			))
		}
	</ul>

	<p class="footer-cta">
		<a class="cta-link" href="/orchestration/">Read the orchestration deep dive →</a>
	</p>
</section>

<style>
	.orch-showcase {
		margin: 4rem 0;
		padding: 2.25rem 2rem;
		border-radius: 16px;
		background: linear-gradient(135deg, var(--brand-primary-soft) 0%, transparent 80%);
		border: 1px solid var(--brand-border);
	}
	.orch-header {
		max-width: 42em;
		margin: 0 0 2rem;
	}
	.eyebrow {
		margin: 0;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--brand-primary);
	}
	.orch-showcase h2 {
		margin: 0.5rem 0 0.75rem;
		font-size: 2rem;
		font-weight: 700;
		letter-spacing: -0.025em;
		color: var(--brand-text);
		line-height: 1.15;
	}
	.lead {
		margin: 0;
		color: var(--brand-text-muted);
		line-height: 1.6;
	}

	/* ── Sub-features (Ecosystem + Orchestration) ──────────────── */
	.subfeature {
		margin: 1.5rem 0;
		padding: 1.5rem 1.75rem;
		background: var(--brand-surface);
		border-left: 3px solid var(--brand-primary);
		border-radius: 0 12px 12px 0;
	}
	.subfeature-head {
		margin: 0 0 0.75rem;
	}
	.subfeature-eyebrow {
		margin: 0 0 0.25rem;
		font-family: var(--brand-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--brand-primary);
	}
	.subfeature h3 {
		margin: 0;
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: -0.015em;
		color: var(--brand-text);
	}
	.subfeature p {
		margin: 0 0 0.75rem;
		color: var(--brand-text);
		line-height: 1.6;
	}
	.subfeature a {
		color: var(--brand-primary);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
	}
	.subfeature a:hover {
		text-decoration: underline;
	}

	.primitives {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1rem;
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
	}
	.primitive {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem;
		border-radius: 12px;
		background: var(--brand-surface);
		border: 1px solid var(--brand-border);
		text-decoration: none;
		color: var(--brand-text);
		height: 100%;
		transition: border-color var(--brand-duration-fast) var(--brand-ease),
			transform var(--brand-duration-fast) var(--brand-ease),
			box-shadow var(--brand-duration-fast) var(--brand-ease);
	}
	.primitive:hover {
		border-color: var(--brand-primary);
		transform: translateY(-2px);
		box-shadow: 0 4px 16px -8px var(--brand-primary);
	}
	.primitive-head {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
	}
	.primitive-icon {
		flex: 0 0 36px;
		width: 36px;
		height: 36px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 9px;
		background: var(--brand-primary-soft);
		color: var(--brand-primary);
	}
	.primitive-icon svg {
		width: 20px;
		height: 20px;
	}
	.primitive h3 {
		margin: 0 0 0.2rem;
		font-size: 1.05rem;
		font-weight: 600;
	}
	.primitive h3 code {
		background: transparent;
		color: var(--brand-primary);
		font-family: var(--brand-font-mono);
		font-size: 1rem;
		padding: 0;
	}
	.primitive-tagline {
		margin: 0;
		font-size: 0.85rem;
		color: var(--brand-text-subtle);
	}
	.primitive-body {
		margin: 0;
		color: var(--brand-text-muted);
		font-size: 0.92rem;
		line-height: 1.55;
	}
	.footer-cta {
		margin: 1.75rem 0 0;
		text-align: right;
	}
	.cta-link {
		color: var(--brand-primary);
		font-weight: 600;
		text-decoration: none;
		font-size: 0.95rem;
	}
	.cta-link:hover {
		text-decoration: underline;
	}
</style>
