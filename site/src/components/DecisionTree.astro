---
/**
 * <DecisionTree /> — "Which verb do I use?" table.
 *
 * Six rows mapping a user situation to the right primitive. Designed so
 * a new user can match in 10 seconds without learning what
 * "orchestration" means.
 *
 * Used on:
 *   - homepage (between OrchestrationShowcase and SwarmShowcase)
 *   - /orchestration/  (replaces the abstract intro)
 *   - /swarm/          (at the top, so swarm-curious users see it too)
 *
 * Two-tier framing per the research: Quick verbs vs Swarm.
 */

const rows = [
	{
		situation: 'Looking up state in one project',
		verb: 'scout',
		tier: 'quick',
		href: '/orchestration/#scout',
		writes: 'read',
	},
	{
		situation: 'Asking a question or running work across N projects, one shot',
		verb: 'dispatch',
		tier: 'quick',
		href: '/orchestration/#dispatch',
		writes: 'both',
	},
	{
		situation: 'Pausing here and letting another session pick up',
		verb: 'handoff',
		tier: 'quick',
		href: '/orchestration/#handoff',
		writes: 'write',
	},
	{
		situation: 'Finding what is waiting for you',
		verb: 'continue',
		tier: 'quick',
		href: '/orchestration/#continue',
		writes: 'read',
	},
	{
		situation: 'Driving a coordinated feature across N projects — multi-hour, dependency-ordered',
		verb: 'swarm',
		tier: 'swarm',
		href: '/swarm/',
		writes: 'write',
	},
	{
		situation: 'Recording a cross-project effort so future sessions find it',
		verb: 'initiative',
		tier: 'foundation',
		href: '/ecosystem/#initiatives',
		writes: 'write',
	},
];

const writesLabel = {
	read: 'read-only',
	write: 'writes',
	both: 'read or write',
};
---

<section class="decision-tree" aria-labelledby="dt-heading">
	<header>
		<p class="eyebrow">Which one do I use?</p>
		<h2 id="dt-heading">Match your situation to the verb.</h2>
		<p class="lead">
			Two tiers, one foundation. <strong>Quick verbs</strong> for
			single-action moves across projects. <strong>Swarm</strong> for
			sustained, dependency-ordered, multi-step work. Both read and write
			the <strong>ecosystem</strong> data layer underneath.
		</p>
	</header>
	<div class="table-wrap">
		<table class="dt-table">
			<thead>
				<tr>
					<th scope="col">Your situation</th>
					<th scope="col">Use</th>
					<th scope="col">Reads / writes</th>
					<th scope="col" class="tier-col">Tier</th>
				</tr>
			</thead>
			<tbody>
				{rows.map((r) => (
					<tr class={`row tier-${r.tier}`}>
						<td class="situation">{r.situation}</td>
						<td class="verb">
							<a href={r.href}>
								<code>{r.verb}</code>
							</a>
						</td>
						<td class="writes">
							<span class={`pill writes--${r.writes}`}>
								{writesLabel[r.writes]}
							</span>
						</td>
						<td class="tier">
							{r.tier === 'quick' && 'Quick verb'}
							{r.tier === 'swarm' && 'Swarm'}
							{r.tier === 'foundation' && 'Ecosystem'}
						</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
</section>

<style>
	.decision-tree {
		margin: 3rem auto 3rem;
		max-width: 1040px;
		padding: 0 0.5rem;
	}
	.decision-tree header {
		text-align: center;
		max-width: 52em;
		margin: 0 auto 1.5rem;
	}
	.eyebrow {
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--brand-primary);
		margin: 0 0 0.35rem;
	}
	#dt-heading {
		font-size: clamp(1.5rem, 2vw, 1.85rem);
		font-weight: 650;
		letter-spacing: -0.022em;
		margin: 0 0 0.5rem;
	}
	.lead {
		color: var(--brand-text-muted);
		font-size: 0.98rem;
		line-height: 1.55;
		margin: 0;
	}

	.table-wrap {
		overflow-x: auto;
		border-radius: 12px;
		border: 1px solid var(--brand-border);
		background: var(--brand-surface-subtle);
	}
	.dt-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.92rem;
	}
	.dt-table th,
	.dt-table td {
		text-align: left;
		padding: 0.85rem 1rem;
		border-bottom: 1px solid var(--brand-border);
		vertical-align: top;
	}
	.dt-table th {
		font-weight: 600;
		font-size: 0.8rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--brand-text-subtle);
		background: var(--brand-surface-muted);
	}
	.dt-table tbody tr:last-child td {
		border-bottom: none;
	}
	.situation {
		font-size: 0.93rem;
		line-height: 1.5;
		color: var(--brand-text);
	}
	.verb a {
		text-decoration: none;
	}
	.verb code {
		font-family: var(--brand-font-mono);
		font-size: 0.92em;
		background: var(--brand-surface-muted);
		padding: 0.15em 0.5em;
		border-radius: 4px;
		color: var(--brand-primary);
	}
	.verb a:hover code {
		text-decoration: underline;
	}
	.tier-col {
		width: 8em;
	}
	.tier {
		font-size: 0.85rem;
		color: var(--brand-text-muted);
	}
	.row.tier-quick .tier { color: var(--brand-primary); }
	.row.tier-swarm .tier { color: var(--brand-accent); font-weight: 600; }
	.row.tier-foundation .tier { color: var(--brand-text-subtle); font-style: italic; }

	.writes {
		width: 8.5em;
	}
	.pill {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.55rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}
	.writes--read {
		background: rgba(99, 102, 241, 0.1); /* indigo @ 10% */
		color: #4338ca; /* indigo-700 */
	}
	:global([data-theme='dark']) .writes--read {
		background: rgba(129, 140, 248, 0.15);
		color: #a5b4fc;
	}
	.writes--write {
		background: rgba(217, 119, 6, 0.14);
		color: #b45309;
	}
	:global([data-theme='dark']) .writes--write {
		background: rgba(251, 191, 36, 0.18);
		color: #fbbf24;
	}
	.writes--both {
		background: rgba(16, 185, 129, 0.13); /* emerald @ 13% */
		color: #047857; /* emerald-700 */
	}
	:global([data-theme='dark']) .writes--both {
		background: rgba(52, 211, 153, 0.18);
		color: #6ee7b7;
	}

	@media (max-width: 640px) {
		.dt-table th,
		.dt-table td {
			padding: 0.65rem 0.8rem;
		}
		.tier-col {
			display: none;
		}
		.row .tier {
			display: none;
		}
	}
</style>
