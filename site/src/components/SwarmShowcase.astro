---
/**
 * <SwarmShowcase /> — landing-page section for Swarm (Phase 17 / v0.20.0).
 *
 * Sits AFTER OrchestrationShowcase. The progression on the page is:
 *
 *   1. Ecosystem mode    — STATE layer (shared manifest, initiatives, sessions)
 *   2. Orchestration     — ACTION verbs (scout / dispatch / handoff / continue)
 *   3. Swarm             — SUSTAINED PARALLEL multi-project feature delivery
 *
 * Layout: eyebrow + headline + lead, then a centered SVG diagram showing
 * conductor → 3 supervisors → per-repo saga records, then a 4-card grid of
 * value props, then CTA + an honest availability note. No client JS;
 * mobile collapses gracefully (single column).
 */

const props = [
	{
		title: 'Wave-ordered execution',
		body:
			'Dependency edges from ecosystem.json compute waves automatically. Cycle detection fails loudly; within-wave order is stable.',
		icon: 'waves',
	},
	{
		title: 'Stateless agents, durable files',
		body:
			'Every state change writes to disk under <code>&lt;eco&gt;/swarms/&lt;id&gt;/</code>. Kill any session; <code>/swarm resume</code> reconstitutes from disk only — no in-memory state.',
		icon: 'disk',
	},
	{
		title: 'Inbox protocol',
		body:
			'Supervisors write questions; the conductor surfaces them on the next turn; you answer; resolved items archive. Mkdir-locked writes, race-safe across siblings.',
		icon: 'inbox',
	},
	{
		title: '95% token saving',
		body:
			'Four layered indexing strategies (board cache + git SHA invalidation + incremental log + cwd-pinned isolation) cap conductor-turn cost at ~3KB. Evidence: p95 of 800–1200 bytes across three scenarios.',
		icon: 'spark',
	},
];
---

<section class="swarm-showcase" aria-labelledby="swarm-heading">
	<header class="swarm-header">
		<p class="eyebrow">Sustained parallel multi-project work</p>
		<h2 id="swarm-heading">One session. Many projects. One feature.</h2>
		<p class="lead">
			A <strong>swarm</strong> is a cross-project work unit driven from
			ONE agent session. Your session becomes the <strong>conductor</strong>;
			one <strong>supervisor</strong> spawns per impacted project, pinned to
			its working directory. Each supervisor runs your normal{' '}
			<code>/start-phase</code> → implement → <code>/sync-docs</code> →{' '}
			<code>/complete-phase</code> loop INSIDE its project. Waves run in
			dependency order; you stay in the cockpit at wave boundaries.
		</p>
	</header>

	{/* ── Conductor + supervisors diagram ─────────────────────────────── */}
	<div class="swarm-diagram" aria-hidden="true">
		<svg
			viewBox="0 0 820 360"
			xmlns="http://www.w3.org/2000/svg"
			role="img"
			aria-label="One conductor spawns one supervisor per project, each pinned to its working directory; saga records live in each project's .momentum/runs"
		>
			<defs>
				<linearGradient id="sw-conductor" x1="0%" y1="0%" x2="0%" y2="100%">
					<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.18" />
					<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0.06" />
				</linearGradient>
				<linearGradient id="sw-super" x1="0%" y1="0%" x2="0%" y2="100%">
					<stop offset="0%" stop-color="var(--brand-accent)" stop-opacity="0.16" />
					<stop offset="100%" stop-color="var(--brand-accent)" stop-opacity="0.04" />
				</linearGradient>
				<marker
					id="sw-arrow"
					viewBox="0 0 10 10"
					refX="9"
					refY="5"
					markerWidth="7"
					markerHeight="7"
					orient="auto"
				>
					<path d="M0,0 L10,5 L0,10 z" fill="var(--brand-text-muted)" />
				</marker>
			</defs>

			{/* Conductor box */}
			<g class="conductor">
				<rect
					x="280"
					y="20"
					width="260"
					height="64"
					rx="10"
					fill="url(#sw-conductor)"
					stroke="var(--brand-primary)"
					stroke-width="1.5"
				/>
				<text x="410" y="48" text-anchor="middle" class="title">
					your session
				</text>
				<text x="410" y="68" text-anchor="middle" class="subtitle">
					= conductor
				</text>
			</g>

			{/* Spawn arrows */}
			<path d="M 410,90 L 130,170" stroke="var(--brand-text-muted)" stroke-width="1.5" fill="none" stroke-dasharray="0" marker-end="url(#sw-arrow)" />
			<path d="M 410,90 L 410,170" stroke="var(--brand-text-muted)" stroke-width="1.5" fill="none" marker-end="url(#sw-arrow)" />
			<path d="M 410,90 L 690,170" stroke="var(--brand-text-muted)" stroke-width="1.5" fill="none" marker-end="url(#sw-arrow)" />
			<text x="265" y="125" text-anchor="middle" class="label-faint">spawn</text>

			{/* Wave 1 supervisor */}
			<g class="supervisor">
				<rect x="40" y="175" width="180" height="68" rx="10" fill="url(#sw-super)" stroke="var(--brand-accent)" stroke-width="1.5" />
				<text x="130" y="200" text-anchor="middle" class="wave">Wave 1</text>
				<text x="130" y="220" text-anchor="middle" class="title">supervisor</text>
				<text x="130" y="236" text-anchor="middle" class="subtitle">shared-types</text>
			</g>

			{/* Wave 2 supervisor */}
			<g class="supervisor">
				<rect x="320" y="175" width="180" height="68" rx="10" fill="url(#sw-super)" stroke="var(--brand-accent)" stroke-width="1.5" />
				<text x="410" y="200" text-anchor="middle" class="wave">Wave 2</text>
				<text x="410" y="220" text-anchor="middle" class="title">supervisor</text>
				<text x="410" y="236" text-anchor="middle" class="subtitle">backend</text>
			</g>

			{/* Wave 3 supervisor */}
			<g class="supervisor">
				<rect x="600" y="175" width="180" height="68" rx="10" fill="url(#sw-super)" stroke="var(--brand-accent)" stroke-width="1.5" />
				<text x="690" y="200" text-anchor="middle" class="wave">Wave 3</text>
				<text x="690" y="220" text-anchor="middle" class="title">supervisor</text>
				<text x="690" y="236" text-anchor="middle" class="subtitle">frontend</text>
			</g>

			{/* Saga records */}
			<g class="saga">
				<rect x="60" y="270" width="140" height="50" rx="6" fill="var(--brand-surface-subtle)" stroke="var(--brand-border)" stroke-dasharray="3 3" />
				<text x="130" y="290" text-anchor="middle" class="saga-label">dispatch-run-NNN.json</text>
				<text x="130" y="306" text-anchor="middle" class="saga-sub">.momentum/runs/</text>
			</g>
			<g class="saga">
				<rect x="340" y="270" width="140" height="50" rx="6" fill="var(--brand-surface-subtle)" stroke="var(--brand-border)" stroke-dasharray="3 3" />
				<text x="410" y="290" text-anchor="middle" class="saga-label">dispatch-run-NNN.json</text>
				<text x="410" y="306" text-anchor="middle" class="saga-sub">.momentum/runs/</text>
			</g>
			<g class="saga">
				<rect x="620" y="270" width="140" height="50" rx="6" fill="var(--brand-surface-subtle)" stroke="var(--brand-border)" stroke-dasharray="3 3" />
				<text x="690" y="290" text-anchor="middle" class="saga-label">dispatch-run-NNN.json</text>
				<text x="690" y="306" text-anchor="middle" class="saga-sub">.momentum/runs/</text>
			</g>

			{/* Write arrows */}
			<path d="M 130,247 L 130,267" stroke="var(--brand-text-muted)" stroke-width="1" fill="none" marker-end="url(#sw-arrow)" />
			<path d="M 410,247 L 410,267" stroke="var(--brand-text-muted)" stroke-width="1" fill="none" marker-end="url(#sw-arrow)" />
			<path d="M 690,247 L 690,267" stroke="var(--brand-text-muted)" stroke-width="1" fill="none" marker-end="url(#sw-arrow)" />

			{/* Dotted feedback arrow back to conductor */}
			<text x="780" y="340" text-anchor="end" class="caption">conductor reads ~3KB board.json per turn — never loads supervisor context</text>
		</svg>
	</div>

	{/* ── Value-prop cards ─────────────────────────────────────────────── */}
	<ul class="props">
		{
			props.map((p) => (
				<li class="prop">
					<span class="prop-icon" aria-hidden="true" data-icon={p.icon}>
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							{p.icon === 'waves' && (
								<>
									<path d="M2 6c2 0 2 2 4 2s2-2 4-2 2 2 4 2 2-2 4-2 2 2 4 2" />
									<path d="M2 12c2 0 2 2 4 2s2-2 4-2 2 2 4 2 2-2 4-2 2 2 4 2" />
									<path d="M2 18c2 0 2 2 4 2s2-2 4-2 2 2 4 2 2-2 4-2 2 2 4 2" />
								</>
							)}
							{p.icon === 'disk' && (
								<>
									<rect x="3" y="3" width="18" height="18" rx="2" />
									<path d="M7 3v6h10V3" />
									<rect x="9" y="13" width="6" height="6" />
								</>
							)}
							{p.icon === 'inbox' && (
								<>
									<polyline points="22 12 16 12 14 15 10 15 8 12 2 12" />
									<path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" />
								</>
							)}
							{p.icon === 'spark' && (
								<>
									<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
								</>
							)}
						</svg>
					</span>
					<h3>{p.title}</h3>
					<p set:html={p.body} />
				</li>
			))
		}
	</ul>

	<footer class="swarm-footer">
		<a class="cta" href="/swarm/">Read the Swarm guide →</a>
		<p class="availability">
			Available on <strong>Claude Code</strong> in v0.20.0. Codex + Antigravity
			parity is the next milestone — testing pending.
		</p>
	</footer>
</section>

<style>
	.swarm-showcase {
		margin: 4rem 0 4rem;
		padding: 0;
	}
	.swarm-header {
		text-align: center;
		max-width: 56em;
		margin: 0 auto 1.75rem;
	}
	.eyebrow {
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--brand-primary);
		margin: 0 0 0.4rem;
	}
	#swarm-heading {
		font-size: clamp(1.6rem, 2.2vw, 2rem);
		font-weight: 650;
		letter-spacing: -0.022em;
		margin: 0 0 0.6rem;
	}
	.lead {
		color: var(--brand-text-muted);
		font-size: 1rem;
		line-height: 1.55;
		margin: 0;
	}
	.lead code {
		font-family: var(--brand-font-mono);
		font-size: 0.92em;
		background: var(--brand-surface-muted);
		padding: 0.05em 0.35em;
		border-radius: 4px;
	}

	/* Diagram */
	.swarm-diagram {
		margin: 2rem auto;
		max-width: 820px;
		padding: 1rem 0.5rem;
	}
	.swarm-diagram svg {
		width: 100%;
		height: auto;
		display: block;
	}
	.swarm-diagram .title {
		font-family: var(--brand-font);
		font-size: 14px;
		font-weight: 600;
		fill: var(--brand-text);
	}
	.swarm-diagram .subtitle {
		font-family: var(--brand-font);
		font-size: 12px;
		fill: var(--brand-text-muted);
	}
	.swarm-diagram .wave {
		font-family: var(--brand-font);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		fill: var(--brand-accent);
	}
	.swarm-diagram .label-faint {
		font-family: var(--brand-font);
		font-size: 11px;
		fill: var(--brand-text-subtle);
		font-style: italic;
	}
	.swarm-diagram .saga-label {
		font-family: var(--brand-font-mono);
		font-size: 11px;
		fill: var(--brand-text);
	}
	.swarm-diagram .saga-sub {
		font-family: var(--brand-font-mono);
		font-size: 10px;
		fill: var(--brand-text-subtle);
	}
	.swarm-diagram .caption {
		font-family: var(--brand-font);
		font-size: 11px;
		fill: var(--brand-text-muted);
		font-style: italic;
	}

	/* Value-prop cards */
	.props {
		list-style: none;
		padding: 0;
		margin: 1.5rem auto 0;
		max-width: 1040px;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
		gap: 1rem;
	}
	.prop {
		background: var(--brand-surface-subtle);
		border: 1px solid var(--brand-border);
		border-radius: 12px;
		padding: 1.1rem 1.2rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		transition: border-color var(--brand-duration-fast) var(--brand-ease);
	}
	.prop:hover {
		border-color: var(--brand-primary);
	}
	.prop-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		color: var(--brand-primary);
	}
	.prop-icon svg {
		width: 22px;
		height: 22px;
	}
	.prop h3 {
		font-size: 1rem;
		font-weight: 600;
		margin: 0;
		letter-spacing: -0.01em;
	}
	.prop p {
		font-size: 0.9rem;
		line-height: 1.5;
		color: var(--brand-text-muted);
		margin: 0;
	}
	.prop code {
		font-family: var(--brand-font-mono);
		font-size: 0.85em;
		background: transparent;
		padding: 0;
		color: var(--brand-text);
	}

	/* Footer */
	.swarm-footer {
		margin: 2rem auto 0;
		max-width: 56em;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
	}
	.cta {
		display: inline-flex;
		align-items: center;
		padding: 0.7rem 1.4rem;
		border-radius: 8px;
		background: var(--brand-primary);
		color: white;
		font-weight: 600;
		text-decoration: none;
		font-size: 0.95rem;
		transition: filter var(--brand-duration-fast) var(--brand-ease),
			transform var(--brand-duration-fast) var(--brand-ease);
	}
	.cta:hover {
		filter: brightness(1.08);
		transform: translateY(-1px);
	}
	.availability {
		font-size: 0.86rem;
		color: var(--brand-text-muted);
		margin: 0;
	}
	.availability strong {
		color: var(--brand-text);
	}

	@media (max-width: 640px) {
		.swarm-diagram {
			padding: 0;
		}
	}
</style>
