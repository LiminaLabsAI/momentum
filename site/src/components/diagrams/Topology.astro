---
/**
 * <Topology /> — single project vs ecosystem visual.
 *
 * Left half:  ONE repo + agent session
 * Right half: ECOSYSTEM ROOT + N member repos, connected to one agent
 *             session in the middle
 *
 * SVG + brand tokens; no animation. Used on the landing
 * "One workflow, many scales" section.
 */
---

<div class="topology" aria-hidden="true">
	<svg
		viewBox="0 0 800 280"
		xmlns="http://www.w3.org/2000/svg"
		role="img"
		aria-label="Single project versus ecosystem mode comparison"
	>
		<defs>
			<linearGradient id="topo-card" x1="0%" y1="0%" x2="0%" y2="100%">
				<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.08" />
				<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0.02" />
			</linearGradient>
		</defs>

		{/* Left — single project */}
		<g class="topo-left">
			<text x="160" y="36" text-anchor="middle" font-size="14" font-weight="600"
				fill="var(--brand-text-muted)" letter-spacing="0.05em">SINGLE PROJECT</text>

			{/* Agent */}
			<g transform="translate(160 100)">
				<rect x="-50" y="-25" width="100" height="50" rx="12"
					fill="url(#topo-card)" stroke="var(--brand-primary)" stroke-width="2" />
				<text y="5" text-anchor="middle" font-size="13" font-weight="600"
					fill="var(--brand-text)">agent</text>
			</g>
			{/* Repo */}
			<g transform="translate(160 220)">
				<rect x="-60" y="-25" width="120" height="50" rx="10"
					fill="var(--brand-surface)" stroke="var(--brand-border-strong)" stroke-width="2" />
				<text y="5" text-anchor="middle" font-size="13" font-weight="500"
					fill="var(--brand-text)">your-project/</text>
			</g>
			{/* Connector */}
			<line x1="160" y1="125" x2="160" y2="195" stroke="var(--brand-accent)" stroke-width="2" />
		</g>

		{/* Divider */}
		<line x1="380" y1="20" x2="380" y2="260" stroke="var(--brand-border)" stroke-width="1" stroke-dasharray="4 4" />

		{/* Right — ecosystem */}
		<g class="topo-right">
			<text x="600" y="36" text-anchor="middle" font-size="14" font-weight="600"
				fill="var(--brand-text-muted)" letter-spacing="0.05em">ECOSYSTEM</text>

			{/* Agent in middle */}
			<g transform="translate(600 100)">
				<rect x="-50" y="-25" width="100" height="50" rx="12"
					fill="url(#topo-card)" stroke="var(--brand-primary)" stroke-width="2" />
				<text y="5" text-anchor="middle" font-size="13" font-weight="600"
					fill="var(--brand-text)">one agent</text>
			</g>

			{/* Ecosystem root */}
			<g transform="translate(600 180)">
				<rect x="-58" y="-20" width="116" height="40" rx="8"
					fill="var(--brand-primary-soft)" stroke="var(--brand-primary)" stroke-width="2" />
				<text y="6" text-anchor="middle" font-size="12" font-weight="600"
					fill="var(--brand-primary)">my-eco/</text>
			</g>

			{/* Three member repos */}
			{
				[
					{ x: 470 },
					{ x: 600 },
					{ x: 730 },
				].map((repo, i) => (
					<g transform={`translate(${repo.x} 250)`}>
						<rect x="-45" y="-15" width="90" height="30" rx="6"
							fill="var(--brand-surface)" stroke="var(--brand-border-strong)" stroke-width="1.5" />
						<text y="4" text-anchor="middle" font-size="11"
							fill="var(--brand-text)">project-{String.fromCharCode(97 + i)}/</text>
					</g>
				))
			}

			{/* Agent → root */}
			<line x1="600" y1="125" x2="600" y2="160" stroke="var(--brand-accent)" stroke-width="2" />
			{/* Root → members */}
			<line x1="600" y1="200" x2="470" y2="235" stroke="var(--brand-accent)" stroke-width="1.5" stroke-dasharray="2 4" />
			<line x1="600" y1="200" x2="600" y2="235" stroke="var(--brand-accent)" stroke-width="1.5" stroke-dasharray="2 4" />
			<line x1="600" y1="200" x2="730" y2="235" stroke="var(--brand-accent)" stroke-width="1.5" stroke-dasharray="2 4" />
		</g>
	</svg>
</div>

<style>
	.topology {
		width: 100%;
		max-width: 800px;
		margin: 2rem auto;
	}
	.topology svg {
		width: 100%;
		height: auto;
		display: block;
	}
</style>
