---
/**
 * <StateActionLayers /> — visualizes the relationship between
 * ecosystem mode (STATE layer) and orchestration (ACTION layer).
 *
 * Top half:    ACTION LAYER — four verbs (scout / dispatch / handoff / continue)
 *              that the agent invokes per task.
 * Bottom half: STATE LAYER — the durable surface those verbs read/write
 *              (ecosystem.json + initiatives + sessions + pointer blocks).
 *
 * Arrows from each verb in the top row down into the state surface.
 * Pure SVG + brand tokens; no animation; mobile collapses gracefully
 * (auto-fit; SVG scales).
 */

const verbs = [
	{ x: 110, label: 'scout' },
	{ x: 300, label: 'dispatch' },
	{ x: 490, label: 'handoff' },
	{ x: 680, label: 'continue' },
];

const stateItems = [
	{ x: 120, label: 'ecosystem.json' },
	{ x: 310, label: 'initiatives/' },
	{ x: 500, label: 'sessions/' },
	{ x: 690, label: 'pointer blocks' },
];
---

<div class="state-action" aria-hidden="true">
	<svg
		viewBox="0 0 800 440"
		xmlns="http://www.w3.org/2000/svg"
		role="img"
		aria-label="Orchestration action layer reads and writes the ecosystem state layer"
	>
		<defs>
			<linearGradient id="sa-action-fill" x1="0%" y1="0%" x2="0%" y2="100%">
				<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.14" />
				<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0.04" />
			</linearGradient>
			<linearGradient id="sa-state-fill" x1="0%" y1="0%" x2="0%" y2="100%">
				<stop offset="0%" stop-color="var(--brand-accent)" stop-opacity="0.06" />
				<stop offset="100%" stop-color="var(--brand-accent)" stop-opacity="0.14" />
			</linearGradient>
			<marker
				id="sa-arrow"
				viewBox="0 0 10 10"
				refX="9"
				refY="5"
				markerUnits="strokeWidth"
				markerWidth="5"
				markerHeight="5"
				orient="auto"
			>
				<path d="M 0 0 L 10 5 L 0 10 Z" fill="var(--brand-primary)" />
			</marker>
		</defs>

		{/* ── ACTION LAYER ──────────────────────────────────────────── */}
		<text x="40" y="32" font-family="ui-monospace, monospace" font-size="11"
			font-weight="700" fill="var(--brand-text-subtle)" letter-spacing="0.12em">
			ACTION LAYER · ORCHESTRATION
		</text>
		<text x="40" y="56" font-size="14" font-weight="600" fill="var(--brand-text)">
			What your agent does
		</text>

		{/* 4 verb cards */}
		{
			verbs.map((v) => (
				<g class="sa-verb" transform={`translate(${v.x} 90)`}>
					<rect
						x="-65"
						y="0"
						width="130"
						height="56"
						rx="10"
						fill="url(#sa-action-fill)"
						stroke="var(--brand-primary)"
						stroke-width="2"
					/>
					<text
						y="34"
						text-anchor="middle"
						font-size="14"
						font-weight="700"
						font-family="ui-monospace, monospace"
						fill="var(--brand-primary)"
					>
						{v.label}
					</text>
				</g>
			))
		}

		{/* Arrows from each verb down into the state surface */}
		{
			verbs.map((v, i) => (
				<line
					x1={v.x}
					y1="148"
					x2={stateItems[i]?.x ?? v.x}
					y2="260"
					stroke="var(--brand-primary)"
					stroke-width="1.5"
					stroke-dasharray="2 4"
					marker-end="url(#sa-arrow)"
					opacity="0.7"
				/>
			))
		}

		{/* "reads + writes" tag in the gap */}
		<g transform="translate(400 200)">
			<rect x="-72" y="-12" width="144" height="24" rx="12"
				fill="var(--brand-surface)" stroke="var(--brand-border)" stroke-width="1" />
			<text y="5" text-anchor="middle" font-size="11" font-weight="600"
				fill="var(--brand-text-muted)" font-family="ui-monospace, monospace">
				reads + writes
			</text>
		</g>

		{/* ── STATE LAYER ───────────────────────────────────────────── */}

		{/* State surface — the floor/foundation */}
		<rect x="40" y="280" width="720" height="140" rx="16"
			fill="url(#sa-state-fill)" stroke="var(--brand-accent)" stroke-width="2" />

		<text x="60" y="304" font-family="ui-monospace, monospace" font-size="11"
			font-weight="700" fill="var(--brand-accent)" letter-spacing="0.12em">
			STATE LAYER · ECOSYSTEM MODE
		</text>
		<text x="60" y="324" font-size="14" font-weight="600" fill="var(--brand-text)">
			What your agent reads + writes (durably)
		</text>

		{/* 4 state item chips */}
		{
			stateItems.map((s) => (
				<g class="sa-state-item" transform={`translate(${s.x} 370)`}>
					<rect
						x="-72"
						y="-18"
						width="144"
						height="36"
						rx="8"
						fill="var(--brand-surface)"
						stroke="var(--brand-border-strong)"
						stroke-width="1.5"
					/>
					<text
						y="6"
						text-anchor="middle"
						font-size="12"
						font-weight="500"
						font-family="ui-monospace, monospace"
						fill="var(--brand-text)"
					>
						{s.label}
					</text>
				</g>
			))
		}
	</svg>

	<p class="state-action-caption">
		<strong>Orchestration</strong> is what the agent does;
		<strong>ecosystem mode</strong> is what those actions read and write.
		Together they're the canonical multi-project pattern — each pointless
		without the other.
	</p>
</div>

<style>
	.state-action {
		width: 100%;
		max-width: 820px;
		margin: 2rem auto 1rem;
	}
	.state-action svg {
		width: 100%;
		height: auto;
		display: block;
	}
	.state-action-caption {
		margin: 1rem auto 0;
		max-width: 50ch;
		text-align: center;
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--brand-text-muted);
	}
	.state-action-caption strong {
		color: var(--brand-text);
		font-weight: 600;
	}
</style>
