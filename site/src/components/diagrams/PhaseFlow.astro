---
/**
 * <PhaseFlow /> — landing-hero diagram.
 *
 * Shows the momentum workflow as five connected nodes:
 *   brainstorm → plan → execute → verify → release
 *
 * Animation: each node lights up sequentially (stroke + halo pulse).
 * No separate pulse circle on the path; the flow is "felt" via the
 * staggered node animations cycling left-to-right.
 *
 * Total cycle = 7.5s (5 nodes × 1.5s each). `prefers-reduced-motion`
 * holds the static state.
 */

const nodes = [
	{ x: 80, label: 'brainstorm', i: 0 },
	{ x: 220, label: 'plan', i: 1 },
	{ x: 360, label: 'execute', i: 2 },
	{ x: 500, label: 'verify', i: 3 },
	{ x: 640, label: 'release', i: 4 },
];
---

<div class="phaseflow" aria-hidden="true">
	<svg
		viewBox="0 0 720 200"
		xmlns="http://www.w3.org/2000/svg"
		role="img"
		aria-label="momentum workflow: brainstorm to plan to execute to verify to release"
	>
		<defs>
			<linearGradient id="pf-fill" x1="0%" y1="0%" x2="0%" y2="100%">
				<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.14" />
				<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0.04" />
			</linearGradient>
		</defs>

		{/* Connecting baseline */}
		<line
			x1="80"
			y1="100"
			x2="640"
			y2="100"
			stroke="var(--brand-border)"
			stroke-width="2"
			stroke-dasharray="4 6"
		/>

		{/* Nodes — 5 stages with staggered lighting */}
		{
			nodes.map((node) => (
				<g
					class="pf-node"
					transform={`translate(${node.x} 100)`}
					style={`--i: ${node.i}`}
				>
					{/* Halo (animated) */}
					<circle class="pf-halo" r="32" fill="var(--brand-primary)" />
					{/* Node body */}
					<circle
						class="pf-body"
						r="32"
						fill="url(#pf-fill)"
						stroke="var(--brand-primary)"
						stroke-width="2"
					/>
					<text
						y="6"
						text-anchor="middle"
						font-size="13"
						font-weight="600"
						fill="var(--brand-text)"
					>
						{node.label}
					</text>
				</g>
			))
		}
	</svg>
</div>

<style>
	.phaseflow {
		width: 100%;
		max-width: 720px;
		margin: 1.5rem auto;
	}
	.phaseflow svg {
		width: 100%;
		height: auto;
		display: block;
	}

	/* The halo is invisible by default; the animation brings it in. */
	.pf-halo {
		opacity: 0;
		transform-box: fill-box;
		transform-origin: center;
		transform: scale(1);
	}

	/* Each node's body has a subtle base stroke; the animation
	 * temporarily boosts opacity + scales the halo. */
	@media (prefers-reduced-motion: no-preference) {
		.pf-halo {
			animation: pf-halo-pulse 7.5s linear infinite;
			animation-delay: calc(var(--i, 0) * 1.5s);
		}
		.pf-body {
			animation: pf-body-pulse 7.5s linear infinite;
			animation-delay: calc(var(--i, 0) * 1.5s);
		}
	}

	@keyframes pf-halo-pulse {
		0%, 100% {
			opacity: 0;
			transform: scale(1);
		}
		5% {
			opacity: 0.22;
			transform: scale(1.18);
		}
		15% {
			opacity: 0;
			transform: scale(1.4);
		}
		20%, 100% {
			opacity: 0;
			transform: scale(1);
		}
	}

	@keyframes pf-body-pulse {
		0%, 100% {
			stroke-width: 2;
		}
		5%, 12% {
			stroke-width: 3.5;
		}
		20%, 100% {
			stroke-width: 2;
		}
	}
</style>
