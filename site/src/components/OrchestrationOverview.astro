---
/**
 * <OrchestrationOverview /> — the umbrella section for multi-project
 * work. Replaces the previous OrchestrationShowcase + SwarmShowcase
 * pair on the homepage.
 *
 * Structure:
 *   1. Section header   "Orchestration."
 *   2. 3-layer stack    SVG showing Swarm > Actions > Ecosystem with
 *                       read/write arrows between layers
 *   3. Three blocks     one per layer with a name + concise lead + CTA
 *
 * The stack diagram literally encodes the umbrella relationship — Swarm
 * and Cross-project actions both sit on top of Ecosystem as the data
 * foundation.
 */

const layers = [
	{
		tag: 'Sustained delivery',
		title: 'Swarm',
		lead:
			'Drive a whole cross-project feature end-to-end from ONE session. Conductor + per-project supervisors, wave-ordered, multi-hour. Survives session kill via disk-only resume.',
		bullets: [
			'Conductor + supervisors, cwd-pinned per project',
			'Wave ordering from ecosystem.json dependencies',
			'Persistent saga state — manifest + board + inbox + contracts',
			'95% token saving via materialized board cache',
		],
		cta: { href: '/swarm/', label: 'Read the swarm guide →' },
		accent: 'swarm',
	},
	{
		tag: 'One-shot actions',
		title: 'Cross-project actions',
		lead:
			'Four single-step verbs the agent runs per task. One move and done — no persistent state, no waves.',
		bullets: [
			'scout — read state from one project',
			'dispatch — fan out work across N projects',
			'handoff — transfer control to another session',
			'continue — pick up an inbox',
		],
		cta: { href: '/orchestration/', label: 'See the four actions →' },
		accent: 'actions',
	},
	{
		tag: 'Foundation — shared data',
		title: 'Ecosystem',
		lead:
			'Shared state on disk that both tiers above read and write. No verbs — just durable substrate.',
		bullets: [
			'ecosystem.json — members + dependency edges',
			'initiatives/ — cross-project feature tracking',
			'sessions/ — daily session log auto-recording commits',
			'pointer blocks in each member project',
		],
		cta: { href: '/ecosystem/', label: 'Read the ecosystem deep dive →' },
		accent: 'foundation',
	},
];
---

<section class="orch-overview" aria-labelledby="orch-overview-heading">
	<header class="overview-header">
		<p class="eyebrow">Across multiple projects</p>
		<h2 id="orch-overview-heading">Orchestration.</h2>
		<p class="lead">
			Three layers that coordinate work across your projects:
			<strong>Ecosystem</strong> (shared state on disk),{' '}
			<strong>Cross-project actions</strong> (one-shot moves), and
			<strong>Swarm</strong> (sustained multi-step delivery). Both upper
			tiers read and write the foundation underneath.
		</p>
	</header>

	{/* ── 3-layer stack diagram ──────────────────────────────────────── */}
	<div class="stack-diagram" aria-hidden="true">
		<svg
			viewBox="0 0 800 460"
			xmlns="http://www.w3.org/2000/svg"
			role="img"
			aria-label="Three-layer orchestration model: Swarm sits on top of Cross-project actions, both read and write the Ecosystem foundation underneath."
		>
			<defs>
				<linearGradient id="ov-swarm" x1="0%" y1="0%" x2="0%" y2="100%">
					<stop offset="0%" stop-color="var(--brand-accent)" stop-opacity="0.20" />
					<stop offset="100%" stop-color="var(--brand-accent)" stop-opacity="0.06" />
				</linearGradient>
				<linearGradient id="ov-actions" x1="0%" y1="0%" x2="0%" y2="100%">
					<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.18" />
					<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0.05" />
				</linearGradient>
				<linearGradient id="ov-foundation" x1="0%" y1="0%" x2="0%" y2="100%">
					<stop offset="0%" stop-color="var(--brand-text-subtle)" stop-opacity="0.12" />
					<stop offset="100%" stop-color="var(--brand-text-subtle)" stop-opacity="0.04" />
				</linearGradient>
				<marker id="ov-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
					<path d="M0,0 L10,5 L0,10 z" fill="var(--brand-text-muted)" />
				</marker>
			</defs>

			{/* Layer 3 (top): Swarm */}
			<g class="layer">
				<rect x="80" y="20" width="640" height="110" rx="14" fill="url(#ov-swarm)" stroke="var(--brand-accent)" stroke-width="1.8" />
				<text x="100" y="50" class="layer-tag">SUSTAINED DELIVERY</text>
				<text x="100" y="82" class="layer-title">Swarm</text>
				<text x="100" y="108" class="layer-sub">Conductor + per-project supervisors · wave-ordered · multi-hour saga</text>
			</g>

			{/* Arrow Swarm → Actions */}
			<line x1="400" y1="135" x2="400" y2="160" stroke="var(--brand-text-muted)" stroke-width="1.5" marker-end="url(#ov-arrow)" />
			<text x="408" y="155" class="arrow-label">reads + writes</text>

			{/* Layer 2 (middle): Actions */}
			<g class="layer">
				<rect x="80" y="170" width="640" height="110" rx="14" fill="url(#ov-actions)" stroke="var(--brand-primary)" stroke-width="1.8" />
				<text x="100" y="200" class="layer-tag">ONE-SHOT ACTIONS</text>
				<text x="100" y="232" class="layer-title">Cross-project actions</text>
				<text x="100" y="258" class="layer-sub">scout · dispatch · handoff · continue — one move and done</text>
			</g>

			{/* Arrow Actions → Foundation */}
			<line x1="400" y1="285" x2="400" y2="310" stroke="var(--brand-text-muted)" stroke-width="1.5" marker-end="url(#ov-arrow)" />
			<text x="408" y="305" class="arrow-label">reads + writes</text>

			{/* Layer 1 (bottom): Foundation */}
			<g class="layer">
				<rect x="80" y="320" width="640" height="110" rx="14" fill="url(#ov-foundation)" stroke="var(--brand-border)" stroke-width="1.8" />
				<text x="100" y="350" class="layer-tag layer-tag--foundation">FOUNDATION — SHARED DATA</text>
				<text x="100" y="382" class="layer-title">Ecosystem</text>
				<text x="100" y="408" class="layer-sub">ecosystem.json + initiatives/ + daily session log + pointer blocks</text>
			</g>
		</svg>
	</div>

	{/* ── Three explanation blocks ───────────────────────────────────── */}
	<div class="layer-blocks">
		{
			layers.map((layer) => (
				<article class={`block block--${layer.accent}`} aria-labelledby={`block-${layer.accent}`}>
					<p class="block-tag">{layer.tag}</p>
					<h3 id={`block-${layer.accent}`}>{layer.title}</h3>
					<p class="block-lead">{layer.lead}</p>
					<ul class="block-bullets">
						{layer.bullets.map((b) => <li>{b}</li>)}
					</ul>
					<a class="block-cta" href={layer.cta.href}>{layer.cta.label}</a>
				</article>
			))
		}
	</div>
</section>

<style>
	.orch-overview {
		margin: 4rem auto;
		max-width: 1080px;
		padding: 0 0.5rem;
	}

	.overview-header {
		text-align: center;
		max-width: 56em;
		margin: 0 auto 2.5rem;
	}
	.eyebrow {
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--brand-primary);
		margin: 0 0 0.4rem;
	}
	#orch-overview-heading {
		font-size: clamp(1.8rem, 2.5vw, 2.4rem);
		font-weight: 650;
		letter-spacing: -0.022em;
		margin: 0 0 0.7rem;
	}
	.lead {
		color: var(--brand-text-muted);
		font-size: 1.02rem;
		line-height: 1.55;
		margin: 0;
	}

	/* ── Stack diagram ──────────────────────────────────────────────── */
	.stack-diagram {
		margin: 0 auto 2.5rem;
		max-width: 800px;
	}
	.stack-diagram svg {
		width: 100%;
		height: auto;
		display: block;
	}
	.stack-diagram .layer-tag {
		font-family: var(--brand-font);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.12em;
		fill: var(--brand-accent);
	}
	.stack-diagram .layer-tag--foundation {
		fill: var(--brand-text-subtle);
	}
	.stack-diagram g.layer:nth-of-type(2) .layer-tag {
		fill: var(--brand-primary);
	}
	.stack-diagram .layer-title {
		font-family: var(--brand-font);
		font-size: 22px;
		font-weight: 650;
		fill: var(--brand-text);
		letter-spacing: -0.01em;
	}
	.stack-diagram .layer-sub {
		font-family: var(--brand-font);
		font-size: 13px;
		fill: var(--brand-text-muted);
	}
	.stack-diagram .arrow-label {
		font-family: var(--brand-font);
		font-size: 10.5px;
		fill: var(--brand-text-subtle);
		font-style: italic;
	}

	/* ── Layer blocks ───────────────────────────────────────────────── */
	.layer-blocks {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.25rem;
		margin: 0;
	}
	.block {
		background: var(--brand-surface-subtle);
		border: 1px solid var(--brand-border);
		border-radius: 14px;
		padding: 1.5rem 1.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		transition: border-color var(--brand-duration-fast) var(--brand-ease),
			transform var(--brand-duration-fast) var(--brand-ease);
	}
	.block:hover {
		transform: translateY(-1px);
	}
	.block--swarm {
		border-top: 4px solid var(--brand-accent);
	}
	.block--swarm:hover {
		border-color: var(--brand-accent);
	}
	.block--actions {
		border-top: 4px solid var(--brand-primary);
	}
	.block--actions:hover {
		border-color: var(--brand-primary);
	}
	.block--foundation {
		border-top: 4px solid var(--brand-text-subtle);
	}
	.block--foundation:hover {
		border-color: var(--brand-text-muted);
	}
	.block-tag {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		color: var(--brand-text-muted);
		margin: 0;
	}
	.block--swarm .block-tag { color: var(--brand-accent); }
	.block--actions .block-tag { color: var(--brand-primary); }
	.block h3 {
		font-size: 1.15rem;
		font-weight: 650;
		margin: 0;
		letter-spacing: -0.01em;
	}
	.block-lead {
		font-size: 0.93rem;
		line-height: 1.55;
		color: var(--brand-text-muted);
		margin: 0;
	}
	.block-bullets {
		list-style: none;
		padding: 0;
		margin: 0.3rem 0 0.6rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.block-bullets li {
		position: relative;
		padding-left: 1.1rem;
		font-size: 0.85rem;
		color: var(--brand-text);
		line-height: 1.4;
	}
	.block-bullets li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55rem;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--brand-text-subtle);
	}
	.block--swarm .block-bullets li::before { background: var(--brand-accent); }
	.block--actions .block-bullets li::before { background: var(--brand-primary); }

	.block-cta {
		display: inline-block;
		margin-top: auto;
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--brand-primary);
		text-decoration: none;
	}
	.block-cta:hover {
		text-decoration: underline;
	}
	.block--swarm .block-cta { color: var(--brand-accent); }

	@media (max-width: 640px) {
		.stack-diagram { padding: 0; }
		.stack-diagram svg { font-size: 14px; }
	}
</style>
