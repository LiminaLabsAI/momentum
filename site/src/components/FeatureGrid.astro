---
/**
 * <FeatureGrid /> — six "what you get" cards.
 */
const features = [
	{
		title: 'Phases',
		body: 'Plan, execute, verify, release. Every phase is a unit of work with a brainstorm, plan, tasks, and history.',
		icon: 'phases',
		href: '/momentum/concepts/#phases',
	},
	{
		title: 'Backlog',
		body: 'Bugs, features, tech debt, and enhancements with priorities and per-item context.',
		icon: 'backlog',
		href: '/momentum/concepts/#backlog',
	},
	{
		title: 'History',
		body: 'Append-only log of decisions, discoveries, and scope changes. The "why" outlives any session.',
		icon: 'history',
		href: '/momentum/concepts/#history',
	},
	{
		title: 'Rules',
		body: 'Thirteen autonomous agent rules — orient first, verify before claim, log every decision.',
		icon: 'rules',
		href: '/momentum/rules/',
	},
	{
		title: 'Skills',
		body: 'Slash commands your AI agent runs automatically — start, complete, sync, review, validate.',
		icon: 'skills',
		href: '/momentum/skills/',
	},
	{
		title: 'Ecosystem',
		body: 'Coordinate multiple related projects from one agent session — opt-in, additive.',
		icon: 'ecosystem',
		href: '/momentum/ecosystem/',
	},
];
---

<section class="feature-grid" aria-labelledby="feature-grid-heading">
	<h2 id="feature-grid-heading">What you get</h2>
	<p class="lead">
		Open-source primitives your agent uses to keep your project's state
		coherent across days, branches, and sessions.
	</p>
	<ul class="features">
		{
			features.map((feature) => (
				<li>
					<a class="feature" href={feature.href}>
						<span class="feature-icon" aria-hidden="true" data-icon={feature.icon}>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								{feature.icon === 'phases' && (
									<>
										<rect x="3" y="4" width="14" height="4" rx="1" />
										<rect x="5" y="10" width="14" height="4" rx="1" />
										<rect x="7" y="16" width="14" height="4" rx="1" />
									</>
								)}
								{feature.icon === 'backlog' && (
									<>
										<rect x="4" y="5" width="16" height="3" rx="1" />
										<rect x="4" y="10" width="16" height="3" rx="1" />
										<rect x="4" y="15" width="10" height="3" rx="1" />
										<circle cx="20" cy="16.5" r="2.5" />
									</>
								)}
								{feature.icon === 'history' && (
									<>
										<path d="M3 12a9 9 0 1 0 3-6.7" />
										<path d="M3 3v5h5" />
										<path d="M12 7v5l3 2" />
									</>
								)}
								{feature.icon === 'rules' && (
									<>
										<path d="M4 4h10l6 6v10a1 1 0 0 1-1 1H4z" />
										<path d="M14 4v6h6" />
										<path d="M8 14h8" />
										<path d="M8 18h6" />
									</>
								)}
								{feature.icon === 'skills' && (
									<>
										<polyline points="8 6 2 12 8 18" />
										<polyline points="16 6 22 12 16 18" />
										<line x1="14" y1="4" x2="10" y2="20" />
									</>
								)}
								{feature.icon === 'ecosystem' && (
									<>
										<circle cx="12" cy="12" r="3" />
										<circle cx="5" cy="5" r="2" />
										<circle cx="19" cy="5" r="2" />
										<circle cx="5" cy="19" r="2" />
										<circle cx="19" cy="19" r="2" />
										<line x1="9.4" y1="9.4" x2="6.5" y2="6.5" />
										<line x1="14.6" y1="9.4" x2="17.5" y2="6.5" />
										<line x1="9.4" y1="14.6" x2="6.5" y2="17.5" />
										<line x1="14.6" y1="14.6" x2="17.5" y2="17.5" />
									</>
								)}
							</svg>
						</span>
						<h3>{feature.title}</h3>
						<p>{feature.body}</p>
					</a>
				</li>
			))
		}
	</ul>
</section>

<style>
	.feature-grid {
		margin: 4rem 0;
	}
	.feature-grid h2 {
		font-size: 1.75rem;
		font-weight: 650;
		letter-spacing: -0.02em;
		margin: 0 0 0.25rem;
	}
	.feature-grid .lead {
		color: var(--brand-text-muted);
		max-width: 38em;
		margin: 0 0 1.5rem;
	}
	.features {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1rem;
	}
	.feature {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.25rem;
		border-radius: 12px;
		background: var(--brand-surface-subtle);
		border: 1px solid var(--brand-border);
		text-decoration: none;
		color: var(--brand-text);
		transition: border-color var(--brand-duration-fast) var(--brand-ease),
			transform var(--brand-duration-fast) var(--brand-ease);
		height: 100%;
	}
	.feature:hover {
		border-color: var(--brand-primary);
		transform: translateY(-2px);
	}
	.feature-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 9px;
		background: var(--brand-primary-soft);
		color: var(--brand-primary);
	}
	.feature-icon svg {
		width: 22px;
		height: 22px;
	}
	.feature h3 {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 600;
	}
	.feature p {
		margin: 0;
		color: var(--brand-text-muted);
		font-size: 0.95rem;
		line-height: 1.5;
	}
</style>
