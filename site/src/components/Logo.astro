---
/**
 * <Logo /> — momentum wordmark (mark + "momentum" text).
 *
 * Inherits color from `currentColor`. Use as-is or wrap in an element
 * that sets `color` to match context (header, footer, hero).
 */
interface Props {
	/** Pixel height of the rendered wordmark. Defaults to 32. */
	size?: number;
	/** Override `aria-label` for screen readers. */
	label?: string;
}

const { size = 32, label = 'momentum' } = Astro.props;
const width = size * (240 / 64); // wordmark viewBox aspect ratio
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 240 64"
	fill="none"
	role="img"
	aria-label={label}
	height={size}
	width={width}
>
	<g transform="translate(0 0)">
		<path
			d="M 8 52 C 16 28 30 12 48 12"
			stroke="currentColor"
			stroke-width="10"
			stroke-linecap="round"
		/>
		<path d="M 40 4 L 60 16 L 44 30 Z" fill="currentColor" />
	</g>
	<text
		x="76"
		y="44"
		fill="currentColor"
		font-family="'Inter Variable', Inter, system-ui, sans-serif"
		font-size="32"
		font-weight="650"
		letter-spacing="-0.02em"
	>momentum</text>
</svg>
