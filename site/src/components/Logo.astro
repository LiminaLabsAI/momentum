---
/**
 * <Logo /> — momentum wordmark (concentric arcs + arrow + "momentum" text).
 *
 * Two-tone treatment: slate-400 arcs (structure), indigo-600 arrow
 * (momentum). Wordmark text adapts to context via `currentColor`.
 */
interface Props {
	/** Pixel height of the rendered wordmark. Defaults to 32. */
	size?: number;
	/** Override `aria-label` for screen readers. */
	label?: string;
}

const { size = 32, label = 'momentum' } = Astro.props;
const width = size * (260 / 64); // wordmark viewBox aspect ratio
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 260 64"
	fill="none"
	role="img"
	aria-label={label}
	height={size}
	width={width}
>
	{/* Mark — concentric arcs + arrow piercing through */}
	<g class="logo-arcs" stroke="#94A3B8" stroke-width="2.5" stroke-linecap="round" fill="none">
		<path d="M 22 22 A 8 8 0 0 1 22 38" />
		<path d="M 22 16 A 14 14 0 0 1 22 44" />
		<path d="M 22 10 A 20 20 0 0 1 22 50" />
	</g>
	<path
		class="logo-arrow-body"
		d="M 10 52 Q 30 30 50 14"
		stroke="#4F46E5"
		stroke-width="6"
		stroke-linecap="round"
		fill="none"
	/>
	<path class="logo-arrow-head" d="M 44 4 L 60 14 L 50 26 Z" fill="#4F46E5" />

	{/* Wordmark */}
	<text
		x="80"
		y="44"
		fill="currentColor"
		font-family="'Inter Variable', Inter, system-ui, sans-serif"
		font-size="32"
		font-weight="650"
		letter-spacing="-0.02em"
	>momentum</text>
</svg>

<style>
	[data-theme='dark'] svg .logo-arcs path {
		stroke: #CBD5E1;
	}
	[data-theme='dark'] svg .logo-arrow-body {
		stroke: #818CF8;
	}
	[data-theme='dark'] svg .logo-arrow-head {
		fill: #818CF8;
	}
</style>
