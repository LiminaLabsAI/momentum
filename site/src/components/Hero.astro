---
/**
 * <Hero /> — illustrated hero background for the landing page.
 *
 * CSS + SVG only (no raster assets). Renders a stylized geometric
 * composition that echoes the brand mark: a swooping arc with
 * decorative dotted "speed lines" trailing behind it on the left,
 * and a subtle phase-stack grid on the right. Respects
 * `prefers-reduced-motion`.
 */
---

<div class="hero-wrap" aria-hidden="true">
	<svg
		class="hero-svg"
		viewBox="0 0 1200 600"
		preserveAspectRatio="xMidYMid slice"
		xmlns="http://www.w3.org/2000/svg"
	>
		<!-- Background gradient -->
		<defs>
			<radialGradient id="halo" cx="65%" cy="40%" r="60%">
				<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.15" />
				<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0" />
			</radialGradient>
			<linearGradient id="arcStroke" x1="0%" y1="100%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0.0" />
				<stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0.45" />
			</linearGradient>
		</defs>

		<!-- Halo behind the curve -->
		<rect x="0" y="0" width="1200" height="600" fill="url(#halo)" />

		<!-- Three echo arcs (speed lines) trailing the main curve -->
		<g class="echo-arcs" fill="none" stroke="url(#arcStroke)" stroke-linecap="round">
			<path d="M 60 540 C 240 360 480 240 720 180" stroke-width="2" stroke-dasharray="2 12" opacity="0.45" />
			<path d="M 80 560 C 280 380 520 260 760 200" stroke-width="2" stroke-dasharray="2 12" opacity="0.3" />
			<path d="M 100 580 C 320 400 560 280 800 220" stroke-width="2" stroke-dasharray="2 12" opacity="0.2" />
		</g>

		<!-- Main velocity arc -->
		<path
			d="M 80 540 C 280 320 540 200 880 180"
			fill="none"
			stroke="var(--brand-primary)"
			stroke-width="14"
			stroke-linecap="round"
			class="arc"
		/>

		<!-- Arrowhead at the tip -->
		<path
			d="M 860 140 L 940 200 L 880 260 Z"
			fill="var(--brand-primary)"
			class="arrow"
		/>

		<!-- Right-side phase-stack grid (subtle layered cards) -->
		<g class="phase-stack" opacity="0.18">
			<rect x="980" y="80" width="180" height="48" rx="8" fill="var(--brand-primary)" />
			<rect x="1000" y="148" width="180" height="48" rx="8" fill="var(--brand-primary)" />
			<rect x="1020" y="216" width="180" height="48" rx="8" fill="var(--brand-primary)" />
			<rect x="1040" y="284" width="180" height="48" rx="8" fill="var(--brand-primary)" />
		</g>
	</svg>
</div>

<style>
	.hero-wrap {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		z-index: 0;
	}
	.hero-svg {
		width: 100%;
		height: 100%;
		display: block;
	}
	.arc,
	.arrow {
		transform-origin: 50% 50%;
	}
	@media (prefers-reduced-motion: no-preference) {
		.arc {
			animation: drift 16s var(--brand-ease) infinite alternate;
		}
		.arrow {
			animation: drift 16s var(--brand-ease) infinite alternate;
		}
		@keyframes drift {
			from { transform: translate(0, 0); }
			to { transform: translate(8px, -4px); }
		}
	}
</style>
