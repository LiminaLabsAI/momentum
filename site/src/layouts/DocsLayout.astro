---
/**
 * DocsLayout — the docs shell (post-Starlight), faithful to Momentum
 * Docs.dc.html: sticky glass topbar, left sidebar, article column, right
 * on-this-page rail, prev/next, a ⌘K command palette, and a light/dark
 * toggle. Built on BaseLayout (theme="auto" → persisted, toggleable).
 */
import BaseLayout from './BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { docsNav, navContext } from '../lib/docsNav';
import '../styles/mermaid.css';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}
interface Props {
	title: string;
	description?: string;
	slug: string;
	headings: Heading[];
}

const { title, description, slug, headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const { group, prev, next } = navContext(slug);

const REPO = 'https://github.com/avinash-singh-io/momentum';
const editUrl = `${REPO}/edit/main/site/src/content/docs/${slug}.md`;

// Command-palette data: every page (title + group) + this page's headings.
const navData = {
	pages: docsNav.flatMap((g) =>
		g.items.map((i) => ({ slug: i.slug, label: i.label, group: g.label }))
	),
	headings: toc.map((h) => ({ id: h.slug, label: h.text })),
};
---

<BaseLayout
	title={`${title} — momentum docs`}
	description={description}
	theme="auto"
	bodyClass="mm-docs"
>
	<!-- TOPBAR -->
	<header class="tb">
		<a class="tb-brand" href="/">
			<span class="tb-mark"><Icon class="ic" name="lucide:chevrons-right" /></span>
			<span class="tb-name">momentum</span>
			<span class="tb-pill">docs</span>
		</a>
		<button type="button" class="tb-search" data-open-palette aria-label="Search docs">
			<Icon class="ic" name="lucide:search" />
			<span>Search docs</span>
			<kbd>⌘K</kbd>
		</button>
		<div class="tb-right">
			<button type="button" class="tb-icon tb-menu" data-toggle-sidebar aria-label="Toggle navigation">
				<Icon class="ic" name="lucide:menu" />
			</button>
			<button type="button" class="tb-icon" data-toggle-theme aria-label="Toggle theme">
				<Icon class="ic" name="lucide:sun-moon" />
			</button>
			<a class="tb-icon" href={REPO} target="_blank" rel="noopener" aria-label="GitHub">
				<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"
					><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
					></path></svg
				>
			</a>
		</div>
	</header>

	<div class="docs-grid" id="top">
		<!-- SIDEBAR -->
		<aside class="sidebar" data-sidebar>
			<nav>
				{
					docsNav.map((g) => (
						<div class="side-group">
							<p class="side-label">{g.label}</p>
							{g.items.map((i) => (
								<a
									class:list={['side-link', { active: i.slug === slug }]}
									href={`/${i.slug}/`}
									aria-current={i.slug === slug ? 'page' : undefined}
								>
									{i.label}
								</a>
							))}
						</div>
					))
				}
			</nav>
		</aside>
		<div class="sidebar-scrim" data-sidebar-scrim aria-hidden="true"></div>

		<!-- ARTICLE -->
		<main class="article">
			<div class="doc-wrap">
				<div class="doc-crumb">
					{group}<span class="sep">›</span><span class="cur">{title}</span>
				</div>
				<div class="doc-head">
					<h1>{title}</h1>
					<a class="kbtn accent" href="https://claude.ai/new" target="_blank" rel="noopener">
						<Icon class="ic" name="lucide:sparkles" />Open in Claude
					</a>
				</div>
				{description && <p class="doc-lead">{description}</p>}

				<article class="doc"><slot /></article>

				<nav class="prevnext">
					{
						prev ? (
							<a class="pn pn-prev" href={`/${prev.slug}/`}>
								<span class="pn-dir">← Previous</span>
								<span class="pn-title">{prev.label}</span>
							</a>
						) : (
							<span />
						)
					}
					{
						next ? (
							<a class="pn pn-next" href={`/${next.slug}/`}>
								<span class="pn-dir">Next →</span>
								<span class="pn-title">{next.label}</span>
							</a>
						) : (
							<span />
						)
					}
				</nav>
			</div>
		</main>

		<!-- ON THIS PAGE -->
		<aside class="toc">
			{
				toc.length > 0 && (
					<div class="toc-inner">
						<p class="side-label">On this page</p>
						{toc.map((h) => (
							<a
								class:list={['toc-link', { sub: h.depth === 3 }]}
								href={`#${h.slug}`}
								data-toc={h.slug}
							>
								{h.text}
							</a>
						))}
						<a class="toc-edit" href={editUrl} target="_blank" rel="noopener">
							<Icon class="ic" name="lucide:pencil" />Edit this page
						</a>
					</div>
				)
			}
		</aside>
	</div>

	<!-- COMMAND PALETTE -->
	<div class="palette" data-palette hidden>
		<div class="palette-box" role="dialog" aria-modal="true" aria-label="Search">
			<div class="palette-head">
				<Icon class="ic" name="lucide:search" />
				<input type="text" data-palette-input placeholder="Search pages and headings…" aria-label="Search pages and headings" />
				<kbd>esc</kbd>
			</div>
			<div class="palette-results" data-palette-results></div>
		</div>
	</div>

	<script type="application/json" is:inline id="mm-nav-data" set:html={JSON.stringify(navData)}></script>
</BaseLayout>

<style is:global>
	/* ============================ docs shell ============================ */
	.mm-docs {
		--tb-h: 56px;
	}

	/* ---- topbar ---- */
	.mm-docs .tb {
		position: sticky;
		top: 0;
		z-index: 40;
		display: flex;
		align-items: center;
		gap: 16px;
		height: var(--tb-h);
		padding: 0 22px;
		background: var(--glass-std);
		backdrop-filter: var(--glass-blur-std);
		-webkit-backdrop-filter: var(--glass-blur-std);
		border-bottom: 1px solid var(--glass-std-bd);
	}
	.mm-docs .tb-brand {
		display: flex;
		align-items: center;
		gap: 9px;
		text-decoration: none;
	}
	.mm-docs .tb-mark {
		display: inline-flex;
		width: 24px;
		height: 24px;
		border-radius: 7px;
		background: var(--brand-ink);
		align-items: center;
		justify-content: center;
	}
	.mm-docs .tb-mark svg {
		width: 15px;
		height: 15px;
		color: #fff;
	}
	.mm-docs .tb-name {
		font-weight: 600;
		font-size: 15px;
		letter-spacing: -0.02em;
		color: var(--fg-0);
	}
	.mm-docs .tb-pill {
		font-size: 11px;
		font-weight: 600;
		color: var(--accent);
		padding: 2px 7px;
		border-radius: 6px;
		background: var(--accent-soft);
		border: 1px solid var(--accent-bd);
	}
	.mm-docs .tb-search {
		display: flex;
		align-items: center;
		gap: 9px;
		height: 34px;
		padding: 0 12px;
		min-width: 240px;
		border-radius: 9px;
		background: var(--bg-3);
		border: 1px solid var(--bd-1);
		color: var(--fg-3);
		font-size: 12.5px;
		font-family: var(--ff-sans);
		cursor: pointer;
	}
	.mm-docs .tb-search svg {
		width: 14px;
		height: 14px;
	}
	.mm-docs .tb-search kbd {
		margin-left: auto;
		font-family: var(--ff-mono);
		font-size: 10.5px;
		padding: 2px 6px;
		border-radius: 5px;
		background: var(--bg-1);
		border: 1px solid var(--bd-1);
	}
	.mm-docs .tb-right {
		margin-left: auto;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.mm-docs .tb-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 8px;
		color: var(--fg-2);
		background: transparent;
		border: 1px solid transparent;
		cursor: pointer;
		text-decoration: none;
		transition: background 0.12s, color 0.12s;
	}
	.mm-docs .tb-icon:hover {
		background: var(--bg-3);
		color: var(--fg-0);
	}
	.mm-docs .tb-icon svg {
		width: 17px;
		height: 17px;
	}
	.mm-docs .tb-menu {
		display: none;
	}

	/* ---- grid ---- */
	.mm-docs .docs-grid {
		display: grid;
		grid-template-columns: 244px minmax(0, 1fr) 210px;
		gap: 34px;
		max-width: 1340px;
		margin: 0 auto;
		padding: 0 24px;
	}
	.mm-docs .sidebar {
		position: sticky;
		top: var(--tb-h);
		align-self: start;
		max-height: calc(100vh - var(--tb-h));
		overflow: auto;
		padding: 26px 6px 40px;
	}
	.mm-docs .side-group {
		margin-bottom: 16px;
	}
	.mm-docs .side-label {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--fg-3);
		padding: 0 10px;
		margin: 0 0 6px;
	}
	.mm-docs .side-link {
		display: block;
		padding: 6px 10px;
		border-radius: 8px;
		font-size: 13px;
		color: var(--fg-2);
		text-decoration: none;
		border: 1px solid transparent;
		transition: background 0.12s, color 0.12s;
	}
	.mm-docs .side-link:hover {
		background: var(--bg-3);
		color: var(--fg-0);
	}
	.mm-docs .side-link.active {
		background: var(--accent-soft);
		border-color: var(--accent-bd);
		color: var(--accent);
		font-weight: 500;
	}
	.mm-docs .sidebar-scrim {
		display: none;
	}

	/* ---- article ---- */
	.mm-docs .article {
		padding: 28px 0 80px;
		min-width: 0;
	}
	.mm-docs .doc-wrap {
		max-width: 760px;
	}
	.mm-docs .doc-crumb {
		display: flex;
		align-items: center;
		gap: 7px;
		font-size: 12px;
		color: var(--fg-3);
	}
	.mm-docs .doc-crumb .sep {
		color: var(--fg-4);
	}
	.mm-docs .doc-crumb .cur {
		color: var(--fg-1);
	}
	.mm-docs .doc-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 16px;
		margin-top: 10px;
	}
	.mm-docs .doc-head h1 {
		margin: 0;
		font-size: 34px;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--fg-0);
		line-height: 1.1;
	}
	.mm-docs .kbtn {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		height: 32px;
		padding: 0 12px;
		border-radius: 8px;
		font-size: 12px;
		font-weight: 500;
		color: var(--fg-1);
		background: var(--bg-1);
		border: 1px solid var(--bd-2);
		cursor: pointer;
		text-decoration: none;
		white-space: nowrap;
		transition: background 0.12s;
	}
	.mm-docs .kbtn:hover {
		background: var(--bg-3);
	}
	.mm-docs .kbtn.accent {
		color: var(--accent);
		border-color: var(--accent-bd);
		background: var(--accent-soft);
	}
	.mm-docs .kbtn svg {
		width: 14px;
		height: 14px;
	}
	.mm-docs .doc-lead {
		font-size: 16.5px;
		color: var(--fg-2);
		line-height: 1.7;
		margin: 16px 0 0;
	}

	/* ---- rendered markdown ---- */
	.mm-docs .doc {
		margin-top: 20px;
	}
	.mm-docs .doc > :first-child {
		margin-top: 0;
	}
	.mm-docs .doc h2 {
		scroll-margin-top: calc(var(--tb-h) + 20px);
		font-size: 23px;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--fg-0);
		margin: 34px 0 12px;
		padding-top: 6px;
		border-top: 1px solid var(--bd-1);
	}
	.mm-docs .doc h3 {
		scroll-margin-top: calc(var(--tb-h) + 20px);
		font-size: 16px;
		font-weight: 600;
		color: var(--fg-0);
		margin: 22px 0 8px;
	}
	.mm-docs .doc p {
		font-size: 15px;
		line-height: 1.72;
		color: var(--fg-1);
		margin: 0 0 14px;
	}
	.mm-docs .doc a {
		color: var(--accent);
		text-decoration: none;
		font-weight: 500;
	}
	.mm-docs .doc a:hover {
		text-decoration: underline;
	}
	.mm-docs .doc strong {
		color: var(--fg-0);
		font-weight: 600;
	}
	.mm-docs .doc :not(pre) > code {
		font-family: var(--ff-mono);
		font-size: 12.5px;
		background: var(--bg-3);
		border: 1px solid var(--bd-1);
		border-radius: 5px;
		padding: 1px 5px;
		color: var(--fg-0);
	}
	.mm-docs .doc ol,
	.mm-docs .doc ul {
		margin: 0 0 14px;
		padding-left: 20px;
	}
	.mm-docs .doc li {
		font-size: 15px;
		line-height: 1.7;
		color: var(--fg-1);
		margin: 0 0 7px;
	}
	.mm-docs .doc blockquote {
		margin: 0 0 16px;
		padding: 4px 16px;
		border-left: 3px solid var(--accent-bd);
		color: var(--fg-2);
	}
	.mm-docs .doc pre {
		position: relative;
		border-radius: 10px;
		border: 1px solid #1f2530;
		padding: 14px 16px;
		margin: 0 0 16px;
		font-size: 12.5px;
		line-height: 1.75;
		overflow: auto;
		tab-size: 2;
	}
	.mm-docs .doc pre code {
		font-family: var(--ff-mono);
		font-size: 12.5px;
	}
	.mm-docs .doc table {
		width: 100%;
		border-collapse: collapse;
		font-size: 14px;
		margin: 0 0 16px;
		display: block;
		overflow-x: auto;
	}
	.mm-docs .doc th,
	.mm-docs .doc td {
		border: 1px solid var(--bd-2);
		padding: 8px 12px;
		text-align: left;
	}
	.mm-docs .doc th {
		background: var(--bg-3);
		color: var(--fg-0);
		font-weight: 600;
	}
	.mm-docs .doc img {
		max-width: 100%;
		height: auto;
		border-radius: 10px;
	}
	.mm-docs .doc hr {
		border: none;
		border-top: 1px solid var(--bd-1);
		margin: 28px 0;
	}

	/* code copy button (injected by JS) */
	.mm-docs .doc .code-copy {
		position: absolute;
		top: 8px;
		right: 8px;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 11px;
		color: #c9d1d9;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 6px;
		padding: 3px 9px;
		cursor: pointer;
		opacity: 0;
		transition: opacity 0.12s, background 0.12s;
	}
	.mm-docs .doc pre:hover .code-copy {
		opacity: 1;
	}
	.mm-docs .doc .code-copy:hover {
		background: rgba(255, 255, 255, 0.12);
	}

	/* ---- asides (remark-asides) ---- */
	.mm-docs .doc-aside {
		display: block;
		padding: 12px 16px;
		border-radius: 12px;
		background: var(--accent-soft);
		border: 1px solid var(--accent-bd);
		margin: 0 0 16px;
	}
	.mm-docs .doc-aside p {
		margin: 0 0 8px;
		font-size: 13.5px;
		color: var(--fg-1);
	}
	.mm-docs .doc-aside p:last-child {
		margin-bottom: 0;
	}
	.mm-docs .doc-aside__title {
		font-weight: 600;
		color: var(--fg-0);
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.mm-docs .doc-aside--tip {
		background: var(--success-soft, rgba(10, 156, 94, 0.08));
		border-color: rgba(10, 156, 94, 0.3);
	}
	.mm-docs .doc-aside--tip .doc-aside__title {
		color: var(--success);
	}
	.mm-docs .doc-aside--caution {
		background: rgba(201, 127, 0, 0.08);
		border-color: rgba(201, 127, 0, 0.32);
	}
	.mm-docs .doc-aside--caution .doc-aside__title {
		color: var(--warning);
	}
	.mm-docs .doc-aside--danger {
		background: rgba(205, 47, 47, 0.08);
		border-color: rgba(205, 47, 47, 0.32);
	}
	.mm-docs .doc-aside--danger .doc-aside__title {
		color: var(--danger);
	}

	/* ---- prev / next ---- */
	.mm-docs .prevnext {
		display: flex;
		gap: 14px;
		margin-top: 36px;
		padding-top: 20px;
		border-top: 1px solid var(--bd-1);
	}
	.mm-docs .pn {
		flex: 1;
		padding: 14px 16px;
		border-radius: 12px;
		border: 1px solid var(--bd-2);
		background: var(--bg-1);
		text-decoration: none;
		transition: border-color 0.12s, background 0.12s;
	}
	.mm-docs .pn:hover {
		border-color: var(--accent-bd);
	}
	.mm-docs .pn-next {
		text-align: right;
	}
	.mm-docs .pn-dir {
		display: block;
		font-size: 11px;
		color: var(--fg-3);
	}
	.mm-docs .pn-title {
		display: block;
		font-size: 14px;
		font-weight: 600;
		color: var(--fg-0);
		margin-top: 3px;
	}
	.mm-docs .pn-next .pn-title {
		color: var(--accent);
	}

	/* ---- on this page ---- */
	.mm-docs .toc {
		position: sticky;
		top: var(--tb-h);
		align-self: start;
		max-height: calc(100vh - var(--tb-h));
		overflow: auto;
		padding: 30px 0 40px;
	}
	.mm-docs .toc .side-label {
		padding: 0 0 10px;
	}
	.mm-docs .toc-link {
		display: block;
		font-size: 12px;
		color: var(--fg-3);
		padding: 5px 0 5px 13px;
		border-left: 2px solid var(--bd-1);
		text-decoration: none;
		transition: color 0.12s, border-color 0.12s;
	}
	.mm-docs .toc-link.sub {
		padding-left: 24px;
	}
	.mm-docs .toc-link:hover {
		color: var(--fg-1);
	}
	.mm-docs .toc-link.active {
		color: var(--accent);
		border-left-color: var(--accent);
		font-weight: 500;
	}
	.mm-docs .toc-edit {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: var(--fg-3);
		text-decoration: none;
		margin-top: 18px;
		padding-top: 14px;
		border-top: 1px solid var(--bd-1);
	}
	.mm-docs .toc-edit:hover {
		color: var(--fg-1);
	}
	.mm-docs .toc-edit svg {
		width: 13px;
		height: 13px;
	}

	/* ---- command palette ---- */
	.mm-docs .palette[hidden] {
		display: none;
	}
	.mm-docs .palette {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 11vh;
		background: rgba(8, 10, 18, 0.42);
		backdrop-filter: blur(3px);
		-webkit-backdrop-filter: blur(3px);
	}
	.mm-docs .palette-box {
		width: min(560px, 92vw);
		border-radius: 16px;
		overflow: hidden;
		background: var(--glass-heavy);
		backdrop-filter: var(--glass-blur-heavy);
		-webkit-backdrop-filter: var(--glass-blur-heavy);
		border: 1px solid var(--glass-heavy-bd);
		box-shadow: var(--shadow-lg);
	}
	.mm-docs .palette-head {
		display: flex;
		align-items: center;
		gap: 11px;
		padding: 14px 18px;
		border-bottom: 1px solid var(--bd-1);
	}
	.mm-docs .palette-head svg {
		width: 17px;
		height: 17px;
		color: var(--fg-3);
	}
	.mm-docs .palette-head input {
		flex: 1;
		border: none;
		outline: none;
		background: transparent;
		font-family: var(--ff-sans);
		font-size: 15px;
		color: var(--fg-0);
	}
	.mm-docs .palette-head kbd {
		font-family: var(--ff-mono);
		font-size: 10.5px;
		color: var(--fg-3);
		padding: 2px 7px;
		border-radius: 5px;
		background: var(--bg-3);
		border: 1px solid var(--bd-1);
	}
	.mm-docs .palette-results {
		max-height: 52vh;
		overflow: auto;
		padding: 8px;
	}
	.mm-docs .pal-item {
		display: flex;
		align-items: center;
		gap: 11px;
		padding: 10px 12px;
		border-radius: 10px;
		cursor: pointer;
		text-decoration: none;
		color: inherit;
	}
	.mm-docs .pal-item:hover,
	.mm-docs .pal-item.active {
		background: var(--bg-3);
	}
	.mm-docs .pal-item svg {
		width: 15px;
		height: 15px;
		color: var(--accent);
		flex: none;
	}
	.mm-docs .pal-label {
		font-size: 13.5px;
		color: var(--fg-0);
		font-weight: 500;
	}
	.mm-docs .pal-sub {
		margin-left: auto;
		font-size: 11.5px;
		color: var(--fg-3);
	}
	.mm-docs .pal-empty {
		padding: 18px 12px;
		font-size: 13px;
		color: var(--fg-3);
		text-align: center;
	}

	/* ---- responsive ---- */
	@media (max-width: 1080px) {
		.mm-docs .docs-grid {
			grid-template-columns: 220px minmax(0, 1fr);
		}
		.mm-docs .toc {
			display: none;
		}
	}
	@media (max-width: 820px) {
		.mm-docs .tb-menu {
			display: inline-flex;
		}
		.mm-docs .tb-search span {
			display: none;
		}
		.mm-docs .tb-search {
			min-width: 0;
			width: 34px;
			padding: 0;
			justify-content: center;
		}
		.mm-docs .tb-search kbd {
			display: none;
		}
		.mm-docs .docs-grid {
			grid-template-columns: minmax(0, 1fr);
		}
		.mm-docs .sidebar {
			position: fixed;
			top: var(--tb-h);
			left: 0;
			bottom: 0;
			width: 260px;
			max-height: none;
			background: var(--bg-1);
			border-right: 1px solid var(--bd-2);
			transform: translateX(-100%);
			transition: transform 0.2s ease;
			z-index: 45;
			padding: 20px 12px 40px;
		}
		.mm-docs .docs-grid.nav-open .sidebar {
			transform: translateX(0);
		}
		.mm-docs .docs-grid.nav-open .sidebar-scrim {
			display: block;
			position: fixed;
			inset: var(--tb-h) 0 0 0;
			background: rgba(8, 10, 18, 0.4);
			z-index: 44;
		}
		.mm-docs .doc-head h1 {
			font-size: 28px;
		}
	}
</style>

<script>
	// ---- theme toggle (persisted; BaseLayout reads mm-theme pre-paint) ----
	const root = document.documentElement;
	for (const b of document.querySelectorAll('[data-toggle-theme]')) {
		b.addEventListener('click', () => {
			const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
			root.dataset.theme = next;
			try {
				localStorage.setItem('mm-theme', next);
			} catch {}
		});
	}

	// ---- mobile sidebar drawer ----
	const grid = document.querySelector('.docs-grid');
	for (const b of document.querySelectorAll('[data-toggle-sidebar]')) {
		b.addEventListener('click', () => grid?.classList.toggle('nav-open'));
	}
	document
		.querySelector('[data-sidebar-scrim]')
		?.addEventListener('click', () => grid?.classList.remove('nav-open'));

	// ---- code copy buttons ----
	for (const pre of document.querySelectorAll('.doc pre')) {
		const btn = document.createElement('button');
		btn.type = 'button';
		btn.className = 'code-copy';
		btn.textContent = 'Copy';
		btn.addEventListener('click', () => {
			const code = pre.querySelector('code')?.innerText ?? pre.innerText;
			navigator.clipboard?.writeText(code);
			btn.textContent = 'Copied';
			window.setTimeout(() => (btn.textContent = 'Copy'), 1200);
		});
		pre.appendChild(btn);
	}

	// ---- TOC scroll-spy ----
	const tocLinks = [...document.querySelectorAll('.toc-link')];
	if (tocLinks.length) {
		const ids = tocLinks.map((l) => l.getAttribute('data-toc'));
		const spy = () => {
			let cur = ids[0];
			for (const id of ids) {
				const el = id && document.getElementById(id);
				if (el && el.getBoundingClientRect().top <= 130) cur = id;
			}
			for (const l of tocLinks)
				l.classList.toggle('active', l.getAttribute('data-toc') === cur);
		};
		window.addEventListener('scroll', spy, { passive: true });
		spy();
	}

	// ---- command palette ----
	const paletteEl = document.querySelector('[data-palette]');
	const input = document.querySelector('[data-palette-input]');
	const resultsEl = document.querySelector('[data-palette-results]');
	let data = { pages: [], headings: [] };
	try {
		data = JSON.parse(document.getElementById('mm-nav-data')?.textContent || '{}');
	} catch {}

	function githubStar() {}
	function buildResults(q) {
		const query = q.trim().toLowerCase();
		const heads = (data.headings || []).map((h) => ({
			icon: 'hash',
			label: h.label,
			sub: 'On this page',
			href: '#' + h.id,
			jump: true,
		}));
		const pages = (data.pages || []).map((p) => ({
			icon: 'file',
			label: p.label,
			sub: p.group,
			href: '/' + p.slug + '/',
		}));
		let all = [...heads, ...pages];
		if (query)
			all = all.filter(
				(r) =>
					r.label.toLowerCase().includes(query) ||
					(r.sub || '').toLowerCase().includes(query)
			);
		return all.slice(0, 8);
	}

	let active = 0;
	function render(items) {
		if (!resultsEl) return;
		if (!items.length) {
			resultsEl.innerHTML = '<div class="pal-empty">No matches</div>';
			return;
		}
		const hashIcon =
			'<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>';
		const fileIcon =
			'<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
		resultsEl.innerHTML = items
			.map(
				(r, i) =>
					`<a class="pal-item${i === active ? ' active' : ''}" href="${r.href}" data-i="${i}"${r.jump ? ' data-jump="1"' : ''}>${r.icon === 'hash' ? hashIcon : fileIcon}<span class="pal-label">${r.label}</span><span class="pal-sub">${r.sub}</span></a>`
			)
			.join('');
	}

	let current = [];
	function refresh() {
		current = buildResults(input && 'value' in input ? input.value : '');
		active = 0;
		render(current);
	}
	function openPalette() {
		if (!paletteEl) return;
		paletteEl.hidden = false;
		if (input) {
			input.value = '';
			refresh();
			setTimeout(() => input.focus(), 20);
		}
	}
	function closePalette() {
		if (paletteEl) paletteEl.hidden = true;
	}
	function go(item) {
		if (!item) return;
		if (item.dataset.jump) {
			closePalette();
			const id = item.getAttribute('href').slice(1);
			const el = document.getElementById(id);
			if (el)
				window.scrollTo({
					top: el.getBoundingClientRect().top + window.scrollY - 76,
					behavior: 'smooth',
				});
		} else {
			window.location.href = item.getAttribute('href');
		}
	}

	for (const b of document.querySelectorAll('[data-open-palette]'))
		b.addEventListener('click', openPalette);
	input?.addEventListener('input', refresh);
	paletteEl?.addEventListener('click', (e) => {
		if (e.target === paletteEl) closePalette();
	});
	resultsEl?.addEventListener('click', (e) => {
		const a = e.target.closest('.pal-item');
		if (a && a.dataset.jump) {
			e.preventDefault();
			go(a);
		}
	});
	window.addEventListener('keydown', (e) => {
		if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
			e.preventDefault();
			paletteEl && paletteEl.hidden ? openPalette() : closePalette();
		} else if (e.key === 'Escape') {
			closePalette();
		} else if (!paletteEl?.hidden) {
			const items = [...(resultsEl?.querySelectorAll('.pal-item') || [])];
			if (!items.length) return;
			if (e.key === 'ArrowDown') {
				e.preventDefault();
				active = (active + 1) % items.length;
				render(current);
			} else if (e.key === 'ArrowUp') {
				e.preventDefault();
				active = (active - 1 + items.length) % items.length;
				render(current);
			} else if (e.key === 'Enter') {
				e.preventDefault();
				go(items[active]);
			}
		}
	});
</script>
