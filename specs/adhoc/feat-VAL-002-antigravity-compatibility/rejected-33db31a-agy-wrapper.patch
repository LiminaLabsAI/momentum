+    } catch (_) {}
+
+    if (!hasAgy) {
+      console.log('  Installing standalone agy CLI wrapper...');
+      const os = require('os');
+      const home = os.homedir();
+      const globalBinDir = path.join(home, '.gemini', 'antigravity', 'bin');
+      const venvDir = path.join(globalBinDir, 'venv');
+      const agyDest = path.join(globalBinDir, 'agy');
+
+      try {
+        if (!fs.existsSync(venvDir)) {
+          console.log(`  Creating virtual environment at ${venvDir}...`);
+          execSync(`python3 -m venv "${venvDir}"`, { stdio: 'inherit' });
+        }
+        console.log('  Installing google-antigravity library...');
+        execSync(`"${venvDir}/bin/pip" install google-antigravity`, { stdio: 'inherit' });
+
+        const wrapperContent = `#!/Users/avinash/.gemini/antigravity/bin/venv/bin/python3
+import sys
+import os
+import argparse
+import asyncio
+from google.antigravity import Agent, LocalAgentConfig, CapabilitiesConfig
+from google.antigravity.hooks import policy
+from google.antigravity.utils.interactive import run_interactive_loop
+
+def load_skill_instructions(skill_name, project_dir):
+    paths = [
+        os.path.join(project_dir, '.agents', 'skills', skill_name, 'SKILL.md'),
+        os.path.join(os.path.expanduser('~'), '.gemini', 'config', 'skills', skill_name, 'SKILL.md'),
+        os.path.join(os.path.expanduser('~'), '.gemini', 'antigravity', 'builtin', 'skills', skill_name, 'SKILL.md')
+    ]
+    for p in paths:
+        if os.path.exists(p):
+            with open(p, 'r', encoding='utf-8') as f:
+                content = f.read()
+            if content.startswith('---'):
+                parts = content.split('---', 2)
+                if len(parts) >= 3:
+                    return parts[2].strip()
+            return content.strip()
+    return None
+
+async def run_agent(args):
+    project_dir = os.path.abspath(args.cwd) if args.cwd else os.getcwd()
+    if args.cwd:
+        os.chdir(args.cwd)
+    system_instructions = None
+    if args.skill:
+        system_instructions = load_skill_instructions(args.skill, project_dir)
+        if not system_instructions:
+            print(f"Error: Skill '{args.skill}' not found.", file=sys.stderr)
+            sys.exit(1)
+    is_interactive = sys.stdin.isatty()
+    if is_interactive:
+        policies = policy.confirm_run_command()
+    else:
+        policies = [policy.allow_all()]
+    config = LocalAgentConfig(
+        system_instructions=system_instructions,
+        capabilities=CapabilitiesConfig(),
+        policies=policies,
+        workspaces=[project_dir],
+    )
+    async with Agent(config) as agent:
+        if is_interactive:
+            await run_interactive_loop(agent)
+        else:
+            prompt = sys.stdin.read()
+            response = await agent.chat(prompt)
+            async for token in response:
+                sys.stdout.write(token)
+                sys.stdout.flush()
+            print()
+
+def main():
+    parser = argparse.ArgumentParser(description="Google Antigravity CLI Wrapper")
+    parser.add_argument('--cwd', type=str, help="Working directory for the agent session")
+    parser.add_argument('--skill', type=str, help="Name of the skill to run")
+    parser.add_argument('--version', '-v', action='store_true', help="Print version info")
+    args = parser.parse_args()
+    if args.version:
+        print("Antigravity CLI (agy) Wrapper v0.1.0")
+        sys.exit(0)
+    asyncio.run(run_agent(args))
+
+if __name__ == '__main__':
+    main()
+`;
+
+        fs.writeFileSync(agyDest, wrapperContent, { mode: 0o755 });
+        console.log(`  ✓ Registered and set agy wrapper executable at ${agyDest}`);
+      } catch (err) {
+        console.log(`  ⚠️  Failed to auto-provision agy CLI: ${err.message}`);
