 15. **Git-lifecycle hooks (Phase 19, FEAT-018/019)** — vendor-neutral, *agent-agnostic* git hooks installed identically for all three adapters: `bin/momentum.js::installGitHooks()` copies `core/git-hooks/*` to the target's `.githooks/` and runs `git config core.hooksPath .githooks` (warn-not-clobber if husky / a custom hooks path exists). `commit-msg` validates Conventional Commits; `pre-push` blocks direct pushes to protected branches without the single-use `.momentum/merge-approved` sentinel and blocks release-tag pushes lacking a non-empty `## Verification Evidence` (Rule 12). Escape hatch: `MOMENTUM_SKIP_HOOKS=1`. These are git hooks, not agent tool-event hooks — the mechanism is identical regardless of agent; the per-column cells exist only for matrix uniformity. Forge-neutral by design (no GitHub/GitLab API); see `core/lifecycle-contract.md`.
 
diff --git a/tests/adapter-antigravity-validation.test.js b/tests/adapter-antigravity-validation.test.js
new file mode 100644
index 0000000..61e2a7d
--- /dev/null
+++ b/tests/adapter-antigravity-validation.test.js
@@ -0,0 +1,54 @@
+'use strict';
+
+/**
+ * Antigravity CLI and parity matrix validation test.
+ *
+ * Verifies that the agy wrapper runs correctly, outputs the correct version,
+ * and that momentum's doctor and init commands configure the Antigravity integration successfully.
+ */
+
+const { test } = require('node:test');
+const assert = require('node:assert/strict');
+const { execSync } = require('node:child_process');
+const fs = require('node:fs');
+const path = require('node:path');
+
+const { mktmp, rmrf, runCli, exists } = require('./_helpers');
+
+test('antigravity CLI wrapper is available on path and executes', () => {
+  let whichRes = '';
+  try {
+    whichRes = execSync('which agy', { encoding: 'utf8' }).trim();
+  } catch (err) {
+    assert.fail('agy CLI wrapper not found on PATH. Run momentum init first.');
+  }
+  assert.ok(whichRes.length > 0);
+});
+
+test('antigravity CLI wrapper outputs correct version and exits 0', () => {
+  const output = execSync('agy --version', { encoding: 'utf8' }).trim();
+  assert.equal(output, 'Antigravity CLI (agy) Wrapper v0.1.0');
+});
+
+test('antigravity CLI wrapper parses arguments and reaches authentication error with mock key', () => {
+  try {
+    execSync('echo "Hello" | GEMINI_API_KEY=mock_key agy --skill momentum-orient', {
+      encoding: 'utf8',
+      stdio: 'pipe',
+    });
+    assert.fail('expected agy to fail with API key error, but it succeeded');
+  } catch (err) {
+    const combinedOutput = err.stdout + '\n' + err.stderr;
+    assert.ok(
+      combinedOutput.includes('API key not valid') || 
+      combinedOutput.includes('AntigravityConnectionError') ||
+      combinedOutput.includes('request failed')
+    );
+  }
+});
+
+test('momentum doctor outputs clean state and detects agy CLI', () => {
+  const res = runCli(['doctor']);
+  assert.equal(res.status, 0);
+  assert.ok(!res.stdout.includes('Diagnostic Warning: "agy" CLI binary is missing on PATH'));
+});
