{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/brainstorm-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-history-reminder.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/sessionstart-handoff.sh"
          }
        ]
      }
    ]
  }
}
