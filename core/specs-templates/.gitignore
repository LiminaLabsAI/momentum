# macOS AppleDouble metadata
._*
.DS_Store

# momentum runtime state — ignore sentinels/runs/inbox, but COMMIT the lock
# file (.momentum/installed.json is the version-of-record; it must travel with
# the repo). Git can't re-include a file under a fully-excluded dir, so ignore
# the contents (.momentum/*) rather than the dir, then negate the lock file.
.momentum/*
!.momentum/installed.json
# Team-mode coordination fragments are COMMITTED (ADR-0012) — cross-machine
# coordination state; the one exception to the ignored .momentum/.
!.momentum/team/
!.momentum/team/**

# Ephemeral agent worktrees (momentum does not manage these — your coding
# agent creates them; they must never pollute tracked state)
.claude/worktrees/

# Node
node_modules/
*.log
